{
	"version": 3,
	"routes": [
		{
			"handle": "filesystem"
		},
		{
			"src": "^/_astro/(.*)$",
			"headers": {
				"cache-control": "public, max-age=31536000, immutable"
			},
			"continue": true
		},
		{
			"src": "^/_server-islands/([^/]+?)/?$",
			"dest": "_render"
		},
		{
			"src": "^/_image/?$",
			"dest": "_render"
		},
		{
			"src": "^/about/?$",
			"dest": "_render"
		},
		{
			"src": "^/admin/instruments/?$",
			"dest": "_render"
		},
		{
			"src": "^/api/contact\\.json/?$",
			"dest": "_render"
		},
		{
			"src": "^/api/health/?$",
			"dest": "_render"
		},
		{
			"src": "^/api/instruments/featured\\.json/?$",
			"dest": "_render"
		},
		{
			"src": "^/api/instruments/index\\.json/?$",
			"dest": "_render"
		},
		{
			"src": "^/api/instruments/([^/]+?)\\.json/?$",
			"dest": "_render"
		},
		{
			"src": "^/blog/?$",
			"dest": "_render"
		},
		{
			"src": "^/calendar/?$",
			"dest": "_render"
		},
		{
			"src": "^/coming-soon/?$",
			"dest": "_render"
		},
		{
			"src": "^/contact/?$",
			"dest": "_render"
		},
		{
			"src": "^/instruments/([^/]+?)/?$",
			"dest": "_render"
		},
		{
			"src": "^/instruments/?$",
			"dest": "_render"
		},
		{
			"src": "^/memories/?$",
			"dest": "_render"
		},
		{
			"src": "^/mywishlist/?$",
			"dest": "_render"
		},
		{
			"src": "^/store/?$",
			"dest": "_render"
		},
		{
			"src": "^/thanks/?$",
			"dest": "_render"
		},
		{
			"src": "^/$",
			"dest": "_render"
		}
	]
}