      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Owner access allowed (200)\", () => pm.response.to.have.status(200));"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "auth": {
          "type": "noauth"
        },
        "method": "GET",
        "header": [
          {
            "key": "Cookie",
            "value": "auth_token={{auth_token_user_b}}",
            "type": "text"
          }
        ],
        "url": {
          "raw": "{{base_url}}/api/contracts/{{contract_id_user_b}}/view",
