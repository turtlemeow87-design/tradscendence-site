---
import BaseLayout from "../../layouts/BaseLayout.astro";
---

<BaseLayout
  title="Admin: Contract Management — Tradscendence"
  description="Upload and manage contracts"
  canonical={`${Astro.url.origin}/admin/contracts`}
>
  <div class="min-h-screen bg-charcoal text-ivory px-4 py-8">
    <div class="max-w-6xl mx-auto">
      
      <!-- Auth Panel -->
      <div id="authPanel" class="mb-8">
        <div class="bg-charcoal/80 frame rounded-xl p-6 max-w-md mx-auto">
          <h1 class="font-display text-2xl text-gold mb-4">Admin Access Required</h1>
          <input
            type="password"
            id="adminKeyInput"
            placeholder="Enter admin key"
            class="w-full bg-charcoal/60 frame rounded-xl px-4 py-2 border border-gold/40 focus:border-gold focus:outline-none mb-4"
          />
          <button
            id="unlockBtn"
            class="w-full rounded-xl px-4 py-2 bg-gold text-ivory hover:bg-gold-dark hover:text-rosewood font-semibold frame transition"
          >
            Unlock
          </button>
          <p id="authError" class="text-rosewood text-sm mt-2 hidden">Invalid admin key</p>
        </div>
      </div>

      <!-- Admin Panel (hidden until unlocked) -->
      <div id="adminContent" class="hidden">
        
        <div class="flex items-center justify-between mb-8">
          <h1 class="font-display text-3xl text-gold">Contract Management</h1>
          <button
            id="refreshBtn"
            class="px-4 py-2 rounded-xl bg-gold/20 text-gold hover:bg-gold hover:text-ivory border border-gold/40 font-semibold frame transition"
          >
            Refresh
          </button>
        </div>

        <div id="submissionsList" class="space-y-6">
          <p class="text-ivory/60 text-center py-8">Loading submissions...</p>
        </div>
      </div>
    </div>
  </div>

  <script>
    let ADMIN_KEY = '';

    // Auth handling
    document.getElementById('unlockBtn')?.addEventListener('click', () => {
      const input = document.getElementById('adminKeyInput') as HTMLInputElement;
      ADMIN_KEY = input.value;
      
      if (ADMIN_KEY) {
        loadSubmissions();
      }
    });

    document.getElementById('adminKeyInput')?.addEventListener('keypress', (e) => {
      if (e.key === 'Enter') {
        document.getElementById('unlockBtn')?.click();
      }
    });

    // Load submissions
    async function loadSubmissions() {
      const authPanel = document.getElementById('authPanel');
      const adminContent = document.getElementById('adminContent');
      const authError = document.getElementById('authError');
      const listEl = document.getElementById('submissionsList');

      if (!listEl) return;

      try {
        // Test auth by fetching submissions (reusing instruments endpoint for auth check)
        const testRes = await fetch('/api/admin/contracts/submissions', {
          headers: { 'x-admin-key': ADMIN_KEY }
        });

        if (!testRes.ok) {
          authError?.classList.remove('hidden');
          return;
        }

        // Auth successful
        authPanel?.classList.add('hidden');
        adminContent?.classList.remove('hidden');

        const data = await testRes.json();
        renderSubmissions(data.submissions);
      } catch (err) {
        console.error('Failed to load submissions:', err);
        listEl.innerHTML = '<p class="text-rosewood text-center py-8">Failed to load submissions</p>';
      }
    }

    function renderSubmissions(submissions: any[]) {
      const listEl = document.getElementById('submissionsList');
      if (!listEl) return;

      if (submissions.length === 0) {
        listEl.innerHTML = '<p class="text-ivory/60 text-center py-8">No submissions found</p>';
        return;
      }

      listEl.innerHTML = submissions.map(sub => `
        <article class="bg-charcoal/80 frame rounded-xl p-6" data-submission-id="${sub.id}">
          <div class="flex flex-wrap items-start justify-between gap-4 mb-4">
            <div>
              <h3 class="font-display text-xl text-gold">${sub.name}</h3>
              <p class="text-ivory/60 text-sm">${sub.email}</p>
              ${sub.event_date ? `<p class="text-ivory/60 text-sm">Event: ${new Date(sub.event_date).toLocaleDateString()}</p>` : ''}
              <p class="text-ivory/60 text-sm">Submitted: ${new Date(sub.created_at).toLocaleDateString()}</p>
            </div>
            <span class="px-3 py-1 rounded-lg border text-sm font-semibold bg-gold/20 text-gold border-gold/40">
              ${sub.status}
            </span>
          </div>

          ${sub.location ? `<p class="text-ivory/80 text-sm mb-2"><span class="text-gold">Location:</span> ${sub.location}</p>` : ''}
          ${sub.instruments?.length ? `<p class="text-ivory/80 text-sm mb-2"><span class="text-gold">Instruments:</span> ${sub.instruments.join(', ')}</p>` : ''}
          
          <div class="mt-6 pt-6 border-t border-gold/20">
            ${sub.contract ? `
              <div class="flex items-center justify-between gap-4">
                <div>
                  <p class="text-green-400 font-semibold mb-1">✓ Contract Uploaded</p>
                  <p class="text-ivory/60 text-sm">Uploaded: ${new Date(sub.contract.uploaded_at).toLocaleDateString()}</p>
                  ${sub.contract.signed_at ? `
                    <p class="text-green-400 text-sm mt-1">
                      Signed by ${sub.contract.signature_name} on ${new Date(sub.contract.signed_at).toLocaleDateString()}
                    </p>
                  ` : '<p class="text-gold text-sm mt-1">Awaiting client signature</p>'}
                </div>
                <a
                  href="${sub.contract.file_url}"
                  target="_blank"
                  rel="noopener noreferrer"
                  class="px-4 py-2 rounded-xl bg-gold/20 text-gold hover:bg-gold hover:text-ivory border border-gold/40 font-semibold transition"
                >
                  View PDF
                </a>
              </div>
            ` : `
              <div>
                <h4 class="font-display text-gold mb-3">Upload Contract</h4>
                <form class="upload-form space-y-3" data-submission-id="${sub.id}">
                  <input
                    type="file"
                    name="file"
                    accept=".pdf"
                    required
                    class="w-full text-ivory/80 text-sm file:mr-4 file:py-2 file:px-4 file:rounded-xl file:border-0 file:bg-gold/20 file:text-gold hover:file:bg-gold hover:file:text-ivory file:cursor-pointer file:font-semibold"
                  />
                  <button
                    type="submit"
                    class="px-6 py-2 rounded-xl bg-gold text-ivory hover:bg-gold-dark hover:text-rosewood font-semibold frame transition"
                  >
                    Upload Contract
                  </button>
                  <p class="error-message text-rosewood text-sm hidden"></p>
                </form>
              </div>
            `}
          </div>
        </article>
      `).join('');

      // Attach upload handlers
      document.querySelectorAll('.upload-form').forEach(form => {
        form.addEventListener('submit', handleUpload);
      });
    }

    async function handleUpload(e: Event) {
      e.preventDefault();
      
      const formEl = e.target as HTMLFormElement;
      const submissionId = formEl.dataset.submissionId;
      const fileInput = formEl.querySelector('input[type="file"]') as HTMLInputElement;
      const errorEl = formEl.querySelector('.error-message') as HTMLElement;
      const submitBtn = formEl.querySelector('button[type="submit"]') as HTMLButtonElement;

      if (!fileInput.files || fileInput.files.length === 0) {
        return;
      }

      const file = fileInput.files[0];
      
      // Validate file type
      if (file.type !== 'application/pdf') {
        errorEl.textContent = 'Only PDF files are allowed';
        errorEl.classList.remove('hidden');
        return;
      }

      // Validate file size (10MB)
      if (file.size > 10 * 1024 * 1024) {
        errorEl.textContent = 'File too large (max 10MB)';
        errorEl.classList.remove('hidden');
        return;
      }

      errorEl.classList.add('hidden');
      submitBtn.disabled = true;
      submitBtn.textContent = 'Uploading...';

      try {
        const formData = new FormData();
        formData.append('submission_id', submissionId!);
        formData.append('file', file);

        const res = await fetch('/api/admin/contracts/upload', {
          method: 'POST',
          headers: { 'x-admin-key': ADMIN_KEY },
          body: formData,
        });

        const data = await res.json();

        if (!res.ok) {
          throw new Error(data.error || 'Upload failed');
        }

        // Success - reload submissions
        loadSubmissions();
      } catch (err: any) {
        errorEl.textContent = err.message || 'Upload failed';
        errorEl.classList.remove('hidden');
        submitBtn.disabled = false;
        submitBtn.textContent = 'Upload Contract';
      }
    }

    // Refresh button
    document.getElementById('refreshBtn')?.addEventListener('click', loadSubmissions);
  </script>
</BaseLayout>