---
import BaseLayout from "../../layouts/BaseLayout.astro";
---

<BaseLayout
  title="Admin: Documents — Tradscendence"
  description="Upload and manage contracts and invoices"
  canonical={`${Astro.url.origin}/admin/contracts`}
>
  <div class="min-h-screen bg-charcoal text-ivory px-4 py-8">
    <div class="max-w-6xl mx-auto">

      <!-- Auth Panel -->
      <div id="authPanel" class="mb-8">
        <div class="bg-charcoal/80 frame rounded-xl p-6 max-w-md mx-auto">
          <h1 class="font-display text-2xl text-gold mb-4">Admin Access Required</h1>
          <input
            type="password"
            id="adminKeyInput"
            placeholder="Enter admin key"
            class="w-full bg-charcoal/60 frame rounded-xl px-4 py-2 border border-gold/40 focus:border-gold focus:outline-none mb-4"
          />
          <button
            id="unlockBtn"
            class="w-full rounded-xl px-4 py-2 bg-gold text-ivory hover:bg-gold-dark hover:text-rosewood font-semibold frame transition"
          >
            Unlock
          </button>
          <p id="authError" class="text-rosewood text-sm mt-2 hidden">Invalid admin key</p>
        </div>
      </div>

      <!-- Admin Panel (hidden until unlocked) -->
      <div id="adminContent" class="hidden">

        <div class="flex items-center justify-between mb-8">
          <h1 class="font-display text-3xl text-gold">Document Management</h1>
          <button
            id="refreshBtn"
            class="px-4 py-2 rounded-xl bg-gold/20 text-gold hover:bg-gold hover:text-ivory border border-gold/40 font-semibold frame transition"
          >
            Refresh
          </button>
        </div>

        <div id="submissionsList" class="space-y-10">
          <p class="text-ivory/60 text-center py-8">Loading submissions...</p>
        </div>
      </div>
    </div>
  </div>

  <script>
    const VALID_STATUSES = [
      "Pending",
      "Reviewing",
      "Contract Sent",
      "Contract Signed",
      "Invoice Sent",
      "Payment Received",
      "Complete",
      "Declined",
    ];

    const STATUS_STYLES: Record<string, string> = {
      "Pending":          "bg-gold/20 text-gold border-gold/40",
      "Reviewing":        "bg-blue-500/20 text-blue-400 border-blue-500/40",
      "Contract Sent":    "bg-purple-500/20 text-purple-400 border-purple-500/40",
      "Contract Signed":  "bg-cyan-500/20 text-cyan-400 border-cyan-500/40",
      "Invoice Sent":     "bg-orange-500/20 text-orange-400 border-orange-500/40",
      "Payment Received": "bg-green-500/20 text-green-400 border-green-500/40",
      "Complete":         "bg-emerald-500/20 text-emerald-400 border-emerald-500/40",
      "Declined":         "bg-rosewood/20 text-rosewood border-rosewood/40",
    };

    let ADMIN_KEY = '';

    document.getElementById('unlockBtn')?.addEventListener('click', () => {
      const input = document.getElementById('adminKeyInput') as HTMLInputElement;
      ADMIN_KEY = input.value;
      if (ADMIN_KEY) loadAll();
    });

    document.getElementById('adminKeyInput')?.addEventListener('keypress', (e) => {
      if (e.key === 'Enter') document.getElementById('unlockBtn')?.click();
    });

    async function loadAll() {
      const authError = document.getElementById('authError');
      const listEl = document.getElementById('submissionsList');
      if (!listEl) return;

      try {
        const [subRes, invRes] = await Promise.all([
          fetch('/api/admin/contracts/submissions', { headers: { 'x-admin-key': ADMIN_KEY } }),
          fetch('/api/admin/invoices/list', { headers: { 'x-admin-key': ADMIN_KEY } }),
        ]);

        if (!subRes.ok) {
          authError?.classList.remove('hidden');
          return;
        }

        document.getElementById('authPanel')?.classList.add('hidden');
        document.getElementById('adminContent')?.classList.remove('hidden');

        const { submissions } = await subRes.json();
        const { invoices } = invRes.ok ? await invRes.json() : { invoices: [] };

        const invoiceMap: Record<number, any[]> = {};
        for (const inv of invoices) {
          if (!invoiceMap[inv.submission_id]) invoiceMap[inv.submission_id] = [];
          invoiceMap[inv.submission_id].push(inv);
        }

        renderSubmissions(submissions, invoiceMap);
      } catch (err) {
        console.error('Failed to load:', err);
        listEl.innerHTML = '<p class="text-rosewood text-center py-8">Failed to load submissions</p>';
      }
    }

    function formatRemindedAt(isoString: string | null): string {
      if (!isoString) return '';
      const d = new Date(isoString);
      return d.toLocaleString('en-US', {
        month: 'short', day: 'numeric', year: 'numeric',
        hour: 'numeric', minute: '2-digit', hour12: true,
      });
    }

    function renderSubmissions(submissions: any[], invoiceMap: Record<number, any[]>) {
      const listEl = document.getElementById('submissionsList');
      if (!listEl) return;

      if (submissions.length === 0) {
        listEl.innerHTML = '<p class="text-ivory/60 text-center py-8">No submissions found</p>';
        return;
      }

      listEl.innerHTML = submissions.map(sub => {
        const invoices = invoiceMap[sub.id] || [];
        const currentStatus = sub.status || 'Pending';
        const badgeClass = STATUS_STYLES[currentStatus] || STATUS_STYLES['Pending'];
        const remindedAt = formatRemindedAt(sub.last_reminded_at);

        return `
        <article
          class="rounded-xl p-6"
          style="${currentStatus === 'Complete'
            ? 'background: #1a1a1a; border: 1px solid #333; opacity: 0.55;'
            : 'background: rgba(17,17,17,0.85); border: 2px solid #C2A45F;'}"
          data-submission-id="${sub.id}">

          <!-- Header row -->
          <div class="flex flex-wrap items-start justify-between gap-4 mb-4">
            <div>
              <h3 class="font-display text-xl text-gold">${sub.name}${sub.preferred_name ? ` <span class="text-ivory/50 text-sm font-sans">(Preferred: ${sub.preferred_name})</span>` : ''}</h3>
              <p class="text-ivory/60 text-sm">${sub.email}</p>
              ${sub.event_date ? `<p class="text-ivory/60 text-sm">Event: ${new Date(sub.event_date).toLocaleDateString()}</p>` : ''}
              <p class="text-ivory/60 text-sm">Submitted: ${new Date(sub.created_at).toLocaleDateString()}</p>
            </div>
            <div class="flex items-center gap-3">
              <span class="status-badge px-3 py-1 rounded-lg border text-sm font-semibold ${badgeClass}">
                ${currentStatus}
              </span>
              <button
                class="delete-submission-btn px-3 py-1 rounded-lg border border-rosewood/60 text-rosewood hover:bg-rosewood hover:text-ivory text-sm font-semibold transition"
                data-submission-id="${sub.id}"
                data-name="${sub.name}"
              >
                Delete
              </button>
            </div>
          </div>

          ${sub.location ? `<p class="text-ivory/80 text-sm mb-2"><span class="text-gold">Location:</span> ${sub.location}</p>` : ''}
          ${sub.instruments?.length ? `<p class="text-ivory/80 text-sm mb-2"><span class="text-gold">Instruments:</span> ${sub.instruments.join(', ')}</p>` : ''}

          <!-- ── Status Control ── -->
          <div class="mt-4 pt-4 border-t border-gold/20">
            <h4 class="font-display text-gold mb-3 text-sm uppercase tracking-wide">Booking Status</h4>
            <div class="flex items-center gap-3 flex-wrap">
              <div class="relative">
                <select
                  class="status-select bg-charcoal frame rounded-xl px-3 py-2 border border-gold/40 text-ivory text-sm focus:outline-none focus:border-gold appearance-none pr-8"
                  data-submission-id="${sub.id}"
                  data-current-status="${currentStatus}"
                  style="background-image: url('data:image/svg+xml;charset=UTF-8,%3Csvg%20xmlns%3D%22http%3A%2F%2Fwww.w3.org%2F2000%2Fsvg%22%20width%3D%2212%22%20height%3D%2212%22%20viewBox%3D%220%200%2024%2024%22%20fill%3D%22none%22%20stroke%3D%22%23C2A45F%22%20stroke-width%3D%222%22%3E%3Cpath%20d%3D%22M6%209l6%206%206-6%22%2F%3E%3C%2Fsvg%3E'); background-repeat: no-repeat; background-position: right 0.6rem center;"
                >
                  ${VALID_STATUSES.map(s => `
                    <option value="${s}" ${s === currentStatus ? 'selected' : ''} class="bg-[#111] text-ivory">${s}</option>
                  `).join('')}
                </select>
              </div>
              <button
                class="save-status-btn px-4 py-2 rounded-xl bg-gold text-ivory hover:bg-gold-dark hover:text-rosewood text-sm font-semibold frame transition"
                data-submission-id="${sub.id}"
              >
                Save Status
              </button>
              <span class="status-feedback text-sm hidden"></span>
            </div>
          </div>

          <!-- ── Reminder Control ── -->
          <div class="mt-4 pt-4 border-t border-gold/20">
            <h4 class="font-display text-gold mb-3 text-sm uppercase tracking-wide">Client Reminder</h4>
            <div class="flex items-center gap-3 flex-wrap">
              <button
                class="send-reminder-btn px-4 py-2 rounded-xl bg-gold/20 text-gold hover:bg-gold hover:text-ivory border border-gold/40 text-sm font-semibold frame transition"
                data-submission-id="${sub.id}"
                data-email="${sub.email}"
              >
                Send Reminder
              </button>
              <span class="remind-timestamp text-ivory/40 text-xs italic">${remindedAt ? `Last sent: ${remindedAt}` : 'Never sent'}</span>
            </div>
          </div>

          <!-- ── Contract Section ── -->
          <div class="mt-6 pt-6 border-t border-gold/20">
            <h4 class="font-display text-gold mb-3">Contract</h4>
            ${sub.contract ? `
              <div class="flex items-center justify-between gap-4">
                <div>
                  <p class="text-green-400 font-semibold mb-1">✓ Contract Uploaded</p>
                  <p class="text-ivory/60 text-sm">Uploaded: ${new Date(sub.contract.uploaded_at).toLocaleDateString()}</p>
                  ${sub.contract.signed_at
                    ? `<p class="text-green-400 text-sm mt-1">Signed by ${sub.contract.signature_name} on ${new Date(sub.contract.signed_at).toLocaleDateString()}</p>`
                    : '<p class="text-gold text-sm mt-1">Awaiting client signature</p>'}
                </div>
                <div class="flex gap-2">
                  <a
                    href="${sub.contract.file_url}"
                    target="_blank"
                    rel="noopener noreferrer"
                    class="px-4 py-2 rounded-xl bg-gold/20 text-gold hover:bg-gold hover:text-ivory border border-gold/40 font-semibold transition"
                  >
                    View PDF
                  </a>
                  <button
                    class="delete-contract-btn px-3 py-2 rounded-xl border border-rosewood/60 text-rosewood hover:bg-rosewood hover:text-ivory text-sm font-semibold transition"
                    data-contract-id="${sub.contract.id}"
                    data-submission-id="${sub.id}"
                    data-signed="${sub.contract.signed_at ? 'true' : 'false'}"
                    data-signer="${sub.contract.signature_name || ''}"
                  >
                    Delete
                  </button>
                </div>
              </div>
            ` : `
              <form class="upload-contract-form space-y-3" data-submission-id="${sub.id}">
                <input
                  type="file"
                  name="file"
                  accept=".pdf"
                  required
                  class="w-full text-ivory/80 text-sm file:mr-4 file:py-2 file:px-4 file:rounded-xl file:border-0 file:bg-gold/20 file:text-gold hover:file:bg-gold hover:file:text-ivory file:cursor-pointer file:font-semibold"
                />
                <button
                  type="submit"
                  class="px-6 py-2 rounded-xl bg-gold text-ivory hover:bg-gold-dark hover:text-rosewood font-semibold frame transition"
                >
                  Upload Contract
                </button>
                <p class="error-message text-rosewood text-sm hidden"></p>
              </form>
            `}
          </div>

          <!-- ── Invoice Section ── -->
          <div class="mt-6 pt-6 border-t border-gold/20">
            <h4 class="font-display text-gold mb-3">Invoices & Receipts</h4>

            ${invoices.length > 0 ? `
              <div class="space-y-2 mb-4">
                ${invoices.map(inv => `
                  <div class="flex items-center justify-between bg-charcoal/60 rounded-lg px-4 py-3 border border-gold/20">
                    <div>
                      <p class="text-ivory/90 font-semibold text-sm">${inv.label}</p>
                      <p class="text-ivory/50 text-xs">Uploaded: ${new Date(inv.uploaded_at).toLocaleDateString()}</p>
                    </div>
                    <div class="flex gap-2">
                      <a
                        href="${inv.file_url}"
                        target="_blank"
                        rel="noopener noreferrer"
                        class="px-3 py-1 rounded-lg bg-gold/20 text-gold hover:bg-gold hover:text-ivory border border-gold/40 text-sm font-semibold transition"
                      >
                        View PDF
                      </a>
                      <button
                        class="delete-invoice-btn px-3 py-1 rounded-lg border border-rosewood/60 text-rosewood hover:bg-rosewood hover:text-ivory text-sm font-semibold transition"
                        data-invoice-id="${inv.id}"
                        data-label="${inv.label}"
                        data-submission-id="${sub.id}"
                      >
                        Delete
                      </button>
                    </div>
                  </div>
                `).join('')}
              </div>
            ` : ''}

            <form class="upload-invoice-form space-y-3" data-submission-id="${sub.id}">
              <div class="flex gap-3">
                <select
                  name="label"
                  class="bg-charcoal/60 frame rounded-xl px-3 py-2 border border-gold/40 focus:border-gold focus:outline-none text-sm text-ivory"
                >
                  <option value="Invoice">Invoice</option>
                  <option value="Receipt">Receipt</option>
                  <option value="Quote">Quote</option>
                </select>
                <input
                  type="file"
                  name="file"
                  accept=".pdf"
                  required
                  class="flex-1 text-ivory/80 text-sm file:mr-4 file:py-2 file:px-4 file:rounded-xl file:border-0 file:bg-gold/20 file:text-gold hover:file:bg-gold hover:file:text-ivory file:cursor-pointer file:font-semibold"
                />
              </div>
              <button
                type="submit"
                class="px-6 py-2 rounded-xl bg-gold text-ivory hover:bg-gold-dark hover:text-rosewood font-semibold frame transition"
              >
                Upload Document
              </button>
              <p class="error-message text-rosewood text-sm hidden"></p>
            </form>
          </div>
        </article>
      `}).join('');

      // Attach all event handlers
      document.querySelectorAll('.upload-contract-form').forEach(form => {
        form.addEventListener('submit', handleContractUpload);
      });
      document.querySelectorAll('.upload-invoice-form').forEach(form => {
        form.addEventListener('submit', handleInvoiceUpload);
      });
      document.querySelectorAll('.save-status-btn').forEach(btn => {
        btn.addEventListener('click', handleStatusSave);
      });
      document.querySelectorAll('.delete-submission-btn').forEach(btn => {
        btn.addEventListener('click', handleDeleteSubmission);
      });
      document.querySelectorAll('.delete-contract-btn').forEach(btn => {
        btn.addEventListener('click', handleContractDelete);
      });
      document.querySelectorAll('.delete-invoice-btn').forEach(btn => {
        btn.addEventListener('click', handleInvoiceDelete);
      });
      document.querySelectorAll('.send-reminder-btn').forEach(btn => {
        btn.addEventListener('click', handleSendReminder);
      });
    }

    // ── Status save handler ──────────────────────────────
    async function handleStatusSave(e: Event) {
      const btn = e.currentTarget as HTMLButtonElement;
      const submissionId = Number(btn.dataset.submissionId);
      const article = btn.closest('article') as HTMLElement;
      const select = article.querySelector('.status-select') as HTMLSelectElement;
      const feedback = article.querySelector('.status-feedback') as HTMLElement;
      const newStatus = select.value;

      btn.disabled = true;
      btn.textContent = 'Saving...';
      feedback.classList.add('hidden');

      try {
        const res = await fetch('/api/admin/status/update', {
          method: 'PATCH',
          headers: { 'x-admin-key': ADMIN_KEY, 'Content-Type': 'application/json' },
          body: JSON.stringify({ submission_id: submissionId, status: newStatus }),
        });

        if (res.status === 401) throw new Error('Session expired — please refresh and re-enter your admin key');
        const data = await res.json();
        if (!res.ok) throw new Error(data.error || 'Failed to update status');

        const badge = article.querySelector('.status-badge') as HTMLElement;
        const STATUS_STYLES: Record<string, string> = {
          "Pending":          "bg-gold/20 text-gold border-gold/40",
          "Reviewing":        "bg-blue-500/20 text-blue-400 border-blue-500/40",
          "Contract Sent":    "bg-purple-500/20 text-purple-400 border-purple-500/40",
          "Contract Signed":  "bg-cyan-500/20 text-cyan-400 border-cyan-500/40",
          "Invoice Sent":     "bg-orange-500/20 text-orange-400 border-orange-500/40",
          "Payment Received": "bg-green-500/20 text-green-400 border-green-500/40",
          "Complete":         "bg-emerald-500/20 text-emerald-400 border-emerald-500/40",
          "Declined":         "bg-rosewood/20 text-rosewood border-rosewood/40",
        };
        badge.className = `status-badge px-3 py-1 rounded-lg border text-sm font-semibold ${STATUS_STYLES[newStatus] || STATUS_STYLES['Pending']}`;
        badge.textContent = newStatus;
        select.dataset.currentStatus = newStatus;

        feedback.textContent = '✓ Saved';
        feedback.className = 'status-feedback text-green-400 text-sm';
        feedback.classList.remove('hidden');
        setTimeout(() => feedback.classList.add('hidden'), 2500);
      } catch (err: any) {
        feedback.textContent = err.message || 'Failed to save';
        feedback.className = 'status-feedback text-rosewood text-sm';
        feedback.classList.remove('hidden');
      } finally {
        btn.disabled = false;
        btn.textContent = 'Save Status';
      }
    }

    // ── Send reminder handler ────────────────────────────
    async function handleSendReminder(e: Event) {
      const btn = e.currentTarget as HTMLButtonElement;
      const submissionId = Number(btn.dataset.submissionId);
      const email = btn.dataset.email || 'this client';
      const article = btn.closest('article') as HTMLElement;
      const timestampEl = article.querySelector('.remind-timestamp') as HTMLElement;

      if (!confirm(`Send a reminder email to ${email}?`)) return;

      btn.disabled = true;
      btn.textContent = 'Sending...';

      try {
        const res = await fetch('/api/admin/remind', {
          method: 'POST',
          headers: { 'x-admin-key': ADMIN_KEY, 'Content-Type': 'application/json' },
          body: JSON.stringify({ submission_id: submissionId }),
        });

        if (res.status === 401) throw new Error('Session expired — please refresh and re-enter your admin key');
        const data = await res.json();
        if (!res.ok) throw new Error(data.error || 'Failed to send reminder');

        // Update timestamp in place without full reload
        if (data.lastRemindedAt && timestampEl) {
          const d = new Date(data.lastRemindedAt);
          const formatted = d.toLocaleString('en-US', {
            month: 'short', day: 'numeric', year: 'numeric',
            hour: 'numeric', minute: '2-digit', hour12: true,
          });
          timestampEl.textContent = `Last sent: ${formatted}`;
        }

        btn.textContent = '✓ Sent';
        setTimeout(() => {
          btn.disabled = false;
          btn.textContent = 'Send Reminder';
        }, 2500);
      } catch (err: any) {
        alert(err.message || 'Failed to send reminder');
        btn.disabled = false;
        btn.textContent = 'Send Reminder';
      }
    }

    // ── Delete submission handler ────────────────────────
    async function handleDeleteSubmission(e: Event) {
      const btn = e.currentTarget as HTMLButtonElement;
      const submissionId = Number(btn.dataset.submissionId);
      const name = btn.dataset.name || 'this submission';

      if (!confirm(`Delete "${name}"?\n\nThis will permanently remove the inquiry and all associated contracts and invoices. This cannot be undone.`)) return;

      btn.disabled = true;
      btn.textContent = 'Deleting...';

      try {
        const res = await fetch('/api/admin/submissions/delete', {
          method: 'DELETE',
          headers: { 'x-admin-key': ADMIN_KEY, 'Content-Type': 'application/json' },
          body: JSON.stringify({ submission_id: submissionId }),
        });

        if (res.status === 401) throw new Error('Session expired — please refresh and re-enter your admin key');
        const data = await res.json();
        if (!res.ok) throw new Error(data.error || 'Failed to delete');

        const article = btn.closest('article') as HTMLElement;
        article.style.transition = 'opacity 0.3s ease';
        article.style.opacity = '0';
        setTimeout(() => article.remove(), 300);
      } catch (err: any) {
        alert(err.message || 'Failed to delete submission');
        btn.disabled = false;
        btn.textContent = 'Delete';
      }
    }

    // ── Contract delete handler ──────────────────────────
    async function handleContractDelete(e: Event) {
      const btn = e.currentTarget as HTMLButtonElement;
      const contractId = Number(btn.dataset.contractId);
      const isSigned = btn.dataset.signed === 'true';
      const signerName = btn.dataset.signer;

      if (!confirm('Delete this contract?\n\nThis will remove the PDF from storage and clear the contract from the client\'s dashboard.')) return;

      if (isSigned) {
        if (!confirm(`⚠️ This contract was digitally signed by "${signerName}".\n\nDeleting it will permanently destroy the signed record and the database audit trail.\n\nAre you absolutely sure you want to delete a signed contract?`)) return;
      }

      btn.disabled = true;
      btn.textContent = 'Deleting...';

      try {
        const res = await fetch('/api/admin/contracts/delete', {
          method: 'DELETE',
          headers: { 'x-admin-key': ADMIN_KEY, 'Content-Type': 'application/json' },
          body: JSON.stringify({ contract_id: contractId }),
        });

        if (res.status === 401) throw new Error('Session expired — please refresh and re-enter your admin key');
        const data = await res.json();
        if (!res.ok) throw new Error(data.error || 'Failed to delete contract');

        loadAll();
      } catch (err: any) {
        alert(err.message || 'Failed to delete contract');
        btn.disabled = false;
        btn.textContent = 'Delete';
      }
    }

    // ── Invoice delete handler ───────────────────────────
    async function handleInvoiceDelete(e: Event) {
      const btn = e.currentTarget as HTMLButtonElement;
      const invoiceId = Number(btn.dataset.invoiceId);
      const label = btn.dataset.label || 'this document';

      if (!confirm(`Delete "${label}"?\n\nThis will remove the PDF from storage and the client will no longer see it in their dashboard.`)) return;

      btn.disabled = true;
      btn.textContent = 'Deleting...';

      try {
        const res = await fetch('/api/admin/invoices/delete', {
          method: 'DELETE',
          headers: { 'x-admin-key': ADMIN_KEY, 'Content-Type': 'application/json' },
          body: JSON.stringify({ invoice_id: invoiceId }),
        });

        if (res.status === 401) throw new Error('Session expired — please refresh and re-enter your admin key');
        const data = await res.json();
        if (!res.ok) throw new Error(data.error || 'Failed to delete document');

        loadAll();
      } catch (err: any) {
        alert(err.message || 'Failed to delete document');
        btn.disabled = false;
        btn.textContent = 'Delete';
      }
    }

    // ── Contract upload handler ──────────────────────────
    async function handleContractUpload(e: Event) {
      e.preventDefault();
      const formEl = e.target as HTMLFormElement;
      const submissionId = formEl.dataset.submissionId;
      const fileInput = formEl.querySelector('input[type="file"]') as HTMLInputElement;
      const errorEl = formEl.querySelector('.error-message') as HTMLElement;
      const submitBtn = formEl.querySelector('button[type="submit"]') as HTMLButtonElement;

      if (!fileInput.files?.length) return;
      const file = fileInput.files[0];

      if (file.type !== 'application/pdf') {
        errorEl.textContent = 'Only PDF files are allowed';
        errorEl.classList.remove('hidden');
        return;
      }
      if (file.size > 10 * 1024 * 1024) {
        errorEl.textContent = 'File too large (max 10MB)';
        errorEl.classList.remove('hidden');
        return;
      }

      errorEl.classList.add('hidden');
      submitBtn.disabled = true;
      submitBtn.textContent = 'Uploading...';

      try {
        const formData = new FormData();
        formData.append('submission_id', submissionId!);
        formData.append('file', file);

        const res = await fetch('/api/admin/contracts/upload', {
          method: 'POST',
          headers: { 'x-admin-key': ADMIN_KEY },
          body: formData,
        });

        if (res.status === 401) throw new Error('Session expired — please refresh the page and re-enter your admin key');
        const data = await res.json();
        if (!res.ok) throw new Error(data.error || 'Upload failed');

        loadAll();
      } catch (err: any) {
        errorEl.textContent = err.message || 'Upload failed';
        errorEl.classList.remove('hidden');
        submitBtn.disabled = false;
        submitBtn.textContent = 'Upload Contract';
      }
    }

    // ── Invoice upload handler ───────────────────────────
    async function handleInvoiceUpload(e: Event) {
      e.preventDefault();
      const formEl = e.target as HTMLFormElement;
      const submissionId = formEl.dataset.submissionId;
      const fileInput = formEl.querySelector('input[type="file"]') as HTMLInputElement;
      const labelSelect = formEl.querySelector('select[name="label"]') as HTMLSelectElement;
      const errorEl = formEl.querySelector('.error-message') as HTMLElement;
      const submitBtn = formEl.querySelector('button[type="submit"]') as HTMLButtonElement;

      if (!fileInput.files?.length) return;
      const file = fileInput.files[0];

      if (file.type !== 'application/pdf') {
        errorEl.textContent = 'Only PDF files are allowed';
        errorEl.classList.remove('hidden');
        return;
      }
      if (file.size > 10 * 1024 * 1024) {
        errorEl.textContent = 'File too large (max 10MB)';
        errorEl.classList.remove('hidden');
        return;
      }

      errorEl.classList.add('hidden');
      submitBtn.disabled = true;
      submitBtn.textContent = 'Uploading...';

      try {
        const formData = new FormData();
        formData.append('submission_id', submissionId!);
        formData.append('file', file);
        formData.append('label', labelSelect.value);

        const res = await fetch('/api/admin/invoices/upload', {
          method: 'POST',
          headers: { 'x-admin-key': ADMIN_KEY },
          body: formData,
        });

        if (res.status === 401) throw new Error('Session expired — please refresh the page and re-enter your admin key');
        const data = await res.json();
        if (!res.ok) throw new Error(data.error || 'Upload failed');

        loadAll();
      } catch (err: any) {
        errorEl.textContent = err.message || 'Upload failed';
        errorEl.classList.remove('hidden');
        submitBtn.disabled = false;
        submitBtn.textContent = 'Upload Document';
      }
    }

    document.getElementById('refreshBtn')?.addEventListener('click', loadAll);
  </script>
</BaseLayout>