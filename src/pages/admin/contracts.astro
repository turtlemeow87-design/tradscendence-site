    async function handleStatusSave(e: Event) {
      const btn          = e.currentTarget as HTMLButtonElement;
      const submissionId = Number(btn.dataset.submissionId);
      const article      = btn.closest('article') as HTMLElement;
      const select       = article.querySelector('.status-select')   as HTMLSelectElement;
      const feedback     = article.querySelector('.status-feedback') as HTMLElement;
      const newStatus    = select.value;

      btn.disabled    = true;
      btn.textContent = 'Saving...';

      try {
        const res = await fetch('/api/admin/status/update', {
          method: 'PATCH',
          headers: { 'x-admin-key': ADMIN_KEY, 'Content-Type': 'application/json' },
          body: JSON.stringify({ submission_id: submissionId, status: newStatus }),
        });
        if (res.status === 401) throw new Error('Session expired — please refresh and re-enter your admin key');
        const data = await res.json();
        if (!res.ok) throw new Error(data.error || 'Failed');

        const badge = article.querySelector('.status-badge') as HTMLElement;
        badge.className = `status-badge px-3 py-1 rounded-lg border text-sm font-semibold ${STATUS_STYLES[newStatus] || STATUS_STYLES['Pending']}`;
        badge.textContent = newStatus;

        feedback.textContent = '✓ Saved';
        feedback.className   = 'status-feedback text-green-400 text-sm';
        feedback.classList.remove('hidden');
        setTimeout(() => feedback.classList.add('hidden'), 2500);
      } catch (err: any) {
        feedback.textContent = err.message || 'Failed';
        feedback.className   = 'status-feedback text-rosewood text-sm';
        feedback.classList.remove('hidden');
      } finally {
        btn.disabled    = false;
        btn.textContent = 'Save Status';
      }
    }

    async function handleSendReminder(e: Event) {
      const btn          = e.currentTarget as HTMLButtonElement;
      const submissionId = Number(btn.dataset.submissionId);
      const email        = btn.dataset.email || 'this client';
      const article      = btn.closest('article') as HTMLElement;
      const timestampEl  = article.querySelector('.remind-timestamp') as HTMLElement;

      if (!confirm(`Send a reminder email to ${email}?`)) return;
      btn.disabled    = true;
      btn.textContent = 'Sending...';

      try {
        const res = await fetch('/api/admin/remind', {
          method: 'POST',
          headers: { 'x-admin-key': ADMIN_KEY, 'Content-Type': 'application/json' },
          body: JSON.stringify({ submission_id: submissionId }),
        });
        if (res.status === 401) throw new Error('Session expired — please refresh and re-enter your admin key');
        const data = await res.json();
        if (!res.ok) throw new Error(data.error || 'Failed');

        if (data.lastRemindedAt && timestampEl) {
          const d = new Date(data.lastRemindedAt);
          timestampEl.textContent = `Last sent: ${d.toLocaleString('en-US', { month: 'short', day: 'numeric', year: 'numeric', hour: 'numeric', minute: '2-digit', hour12: true })}`;
        }
        btn.textContent = '✓ Sent';
        setTimeout(() => { btn.disabled = false; btn.textContent = 'Send Reminder'; }, 2500);
      } catch (err: any) {
        alert(err.message || 'Failed');
        btn.disabled    = false;
        btn.textContent = 'Send Reminder';
      }
    }

    async function handleDeleteSubmission(e: Event) {
      const btn          = e.currentTarget as HTMLButtonElement;
      const submissionId = Number(btn.dataset.submissionId);
      const name         = btn.dataset.name || 'this submission';

      if (!confirm(`Delete "${name}"?\n\nThis will permanently remove the inquiry and all associated contracts and invoices.`)) return;
      btn.disabled    = true;
      btn.textContent = 'Deleting...';

      try {
        const res = await fetch('/api/admin/submissions/delete', {
          method: 'DELETE',
          headers: { 'x-admin-key': ADMIN_KEY, 'Content-Type': 'application/json' },
          body: JSON.stringify({ submission_id: submissionId }),
        });
        if (res.status === 401) throw new Error('Session expired — please refresh and re-enter your admin key');
        const data = await res.json();
        if (!res.ok) throw new Error(data.error || 'Failed');

        const article = btn.closest('article') as HTMLElement;
        article.style.transition = 'opacity 0.3s ease';
        article.style.opacity    = '0';
        setTimeout(() => article.remove(), 300);
      } catch (err: any) {
        alert(err.message || 'Failed');
        btn.disabled    = false;
        btn.textContent = 'Delete';
      }
    }

    async function handleContractDelete(e: Event) {
      const btn        = e.currentTarget as HTMLButtonElement;
      const contractId = Number(btn.dataset.contractId);
      const isSigned   = btn.dataset.signed === 'true';
      const signerName = btn.dataset.signer;

      if (!confirm('Delete this contract? This will remove the PDF from storage.')) return;
      if (isSigned && !confirm(`⚠️ Signed by "${signerName}". This destroys the audit trail. Are you absolutely sure?`)) return;

      btn.disabled    = true;
      btn.textContent = 'Deleting...';

      try {
        const res = await fetch('/api/admin/contracts/delete', {
          method: 'DELETE',
          headers: { 'x-admin-key': ADMIN_KEY, 'Content-Type': 'application/json' },
          body: JSON.stringify({ contract_id: contractId }),
        });
        if (res.status === 401) throw new Error('Session expired — please refresh and re-enter your admin key');
        const data = await res.json();
        if (!res.ok) throw new Error(data.error || 'Failed');
        loadAll();
      } catch (err: any) {
        alert(err.message || 'Failed');
        btn.disabled    = false;
        btn.textContent = 'Delete';
      }
    }

    async function handleInvoiceDelete(e: Event) {
      const btn       = e.currentTarget as HTMLButtonElement;
      const invoiceId = Number(btn.dataset.invoiceId);
      const label     = btn.dataset.label || 'this document';

      if (!confirm(`Delete "${label}"? The client will no longer see it.`)) return;
      btn.disabled    = true;
      btn.textContent = 'Deleting...';

      try {
        const res = await fetch('/api/admin/invoices/delete', {
          method: 'DELETE',
          headers: { 'x-admin-key': ADMIN_KEY, 'Content-Type': 'application/json' },
          body: JSON.stringify({ invoice_id: invoiceId }),
        });
        if (res.status === 401) throw new Error('Session expired — please refresh and re-enter your admin key');
        const data = await res.json();
        if (!res.ok) throw new Error(data.error || 'Failed');
        loadAll();
      } catch (err: any) {
        alert(err.message || 'Failed');
        btn.disabled    = false;
        btn.textContent = 'Delete';
      }
    }

    async function handleContractUpload(e: Event) {
      e.preventDefault();
      const formEl       = e.target as HTMLFormElement;
      const submissionId = formEl.dataset.submissionId;
      const fileInput    = formEl.querySelector('input[type="file"]') as HTMLInputElement;
      const errorEl      = formEl.querySelector('.error-message')     as HTMLElement;
      const submitBtn    = formEl.querySelector('button[type="submit"]') as HTMLButtonElement;

      if (!fileInput.files?.length) return;
      const file = fileInput.files[0];
      if (file.type !== 'application/pdf') { errorEl.textContent = 'Only PDF files are allowed'; errorEl.classList.remove('hidden'); return; }
      if (file.size > 10 * 1024 * 1024)    { errorEl.textContent = 'File too large (max 10MB)';  errorEl.classList.remove('hidden'); return; }

      errorEl.classList.add('hidden');
      submitBtn.disabled    = true;
      submitBtn.textContent = 'Uploading...';

      try {
        const formData = new FormData();
        formData.append('submission_id', submissionId!);
        formData.append('file', file);

        const res = await fetch('/api/admin/contracts/upload', {
          method: 'POST', headers: { 'x-admin-key': ADMIN_KEY }, body: formData,
        });
        if (res.status === 401) throw new Error('Session expired — please refresh and re-enter your admin key');
        const data = await res.json();
        if (!res.ok) throw new Error(data.error || 'Upload failed');
        loadAll();
      } catch (err: any) {
        errorEl.textContent = err.message || 'Upload failed';
        errorEl.classList.remove('hidden');
        submitBtn.disabled    = false;
        submitBtn.textContent = 'Upload Contract';
      }
    }

    async function handleInvoiceUpload(e: Event) {
      e.preventDefault();
      const formEl       = e.target as HTMLFormElement;
      const submissionId = formEl.dataset.submissionId;
      const fileInput    = formEl.querySelector('input[type="file"]')      as HTMLInputElement;
      const labelSelect  = formEl.querySelector('select[name="label"]')   as HTMLSelectElement;
      const errorEl      = formEl.querySelector('.error-message')          as HTMLElement;
      const submitBtn    = formEl.querySelector('button[type="submit"]')   as HTMLButtonElement;

      if (!fileInput.files?.length) return;
      const file = fileInput.files[0];
      if (file.type !== 'application/pdf') { errorEl.textContent = 'Only PDF files are allowed'; errorEl.classList.remove('hidden'); return; }
      if (file.size > 10 * 1024 * 1024)    { errorEl.textContent = 'File too large (max 10MB)';  errorEl.classList.remove('hidden'); return; }

      errorEl.classList.add('hidden');
      submitBtn.disabled    = true;
      submitBtn.textContent = 'Uploading...';

      try {
        const formData = new FormData();
        formData.append('submission_id', submissionId!);
        formData.append('file', file);
        formData.append('label', labelSelect.value);

        const res = await fetch('/api/admin/invoices/upload', {
          method: 'POST', headers: { 'x-admin-key': ADMIN_KEY }, body: formData,
        });
        if (res.status === 401) throw new Error('Session expired — please refresh and re-enter your admin key');
        const data = await res.json();
        if (!res.ok) throw new Error(data.error || 'Upload failed');
        loadAll();
      } catch (err: any) {
        errorEl.textContent = err.message || 'Upload failed';
        errorEl.classList.remove('hidden');
        submitBtn.disabled    = false;
        submitBtn.textContent = 'Upload Document';
      }
    }

    // ── Top-level event listeners ─────────────────────────
    document.getElementById('refreshBtn')?.addEventListener('click', loadAll);
    document.getElementById('refreshReviewsBtn')?.addEventListener('click', loadReviews);
  </script>
</BaseLayout>