---
import BaseLayout from "../layouts/BaseLayout.astro";
import { neon } from "@neondatabase/serverless";

const title = "Memories — Tradscendence | Sound Beyond Borders";
const description =
  "A living journal of performances — reflections, images, and the words of those who were there.";

type MemoryRow = {
  id: number;
  title: string;
  event_date: string | null;
  location: string | null;
  reflection: string | null;
  photo_urls: string[];
  video_src: string | null;
  review_body: string | null;
  reviewer_name: string | null;
};

let memoryRows: MemoryRow[] = [];

if (!import.meta.env.DEV && import.meta.env.DATABASE_URL) {
  const sql = neon(import.meta.env.DATABASE_URL);
  try {
    const rows = await sql`
      SELECT
        m.id,
        m.title,
        m.event_date,
        m.location,
        m.reflection,
        m.photo_urls,
        m.video_src,
        r.body AS review_body,
        COALESCE(
          u.preferred_name,
          CONCAT(LEFT(u.first_name, 1), '. ', u.last_name)
        ) AS reviewer_name
      FROM memories m
      LEFT JOIN reviews r
        ON m.submission_id = r.submission_id
        AND r.approved = true
      LEFT JOIN users u ON r.user_id = u.id
      WHERE m.visible = true
      ORDER BY m.event_date DESC NULLS LAST, m.display_order ASC
    `;
    memoryRows = rows as MemoryRow[];
  } catch (err) {
    console.error("Failed to load memories:", err);
  }
}

// Dev fallback
if (import.meta.env.DEV && memoryRows.length === 0) {
  memoryRows = [
    {
      id: 1,
      title: "Palestinian-Style Wedding",
      event_date: "2024-09-13",
      location: "Wintergreen, VA",
      reflection: "This was a beautiful wedding in the mountains, where I took the opportunity to enhance the atmosphere with some Arabic-style taqsim. The entire trip was a pleasure, the couple and their family were very warm, and I am proud to have this as my first professional memory with music.",
      photo_urls: ["/media/BrideandGroom1.jpg"],
      video_src: "/media/PalestinianOud.mp4",
      review_body: null,
      reviewer_name: null,
    },
  ];
}

function formatDate(d: string | null) {
  if (!d) return "";
  return new Date(d).toLocaleDateString("en-US", {
    year: "numeric", month: "long", day: "numeric",
  });
}

function truncate(text: string, len = 120) {
  if (text.length <= len) return text;
  return text.slice(0, len).trimEnd() + "…";
}
---

<BaseLayout {title} description={description}>
  <!-- GLightbox -->
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/glightbox/3.2.0/css/glightbox.min.css" />

  <!-- Page-scoped dreamy styles -->
  <style>
    /* ── Starfield background ─────────────────────────── */
    .memories-bg {
      position: fixed;
      inset: 0;
      z-index: 0;
      pointer-events: none;
      background:
        radial-gradient(ellipse 80% 50% at 20% 10%, rgba(110,42,42,0.08) 0%, transparent 60%),
        radial-gradient(ellipse 60% 40% at 80% 80%, rgba(194,164,95,0.05) 0%, transparent 55%),
        radial-gradient(ellipse 100% 100% at 50% 50%, rgba(30,20,40,0.4) 0%, transparent 70%);
    }

    .star {
      position: absolute;
      border-radius: 50%;
      background: rgba(245,241,232,0.6);
      animation: twinkle var(--dur, 4s) ease-in-out infinite;
      animation-delay: var(--delay, 0s);
    }

    @keyframes twinkle {
      0%, 100% { opacity: var(--min-op, 0.1); transform: scale(1); }
      50%       { opacity: var(--max-op, 0.6); transform: scale(1.3); }
    }

    /* ── Timeline ─────────────────────────────────────── */
    .timeline-line {
      position: absolute;
      left: 7px;
      top: 0;
      bottom: 0;
      width: 2px;
      background: linear-gradient(
        to bottom,
        transparent,
        var(--accent-gold) 8%,
        var(--accent-gold) 92%,
        transparent
      );
      box-shadow: 0 0 8px rgba(194,164,95,0.25);
    }

    .timeline-dot {
      position: absolute;
      left: -1px;
      top: 6px;
      width: 16px;
      height: 16px;
      border-radius: 50%;
      background: var(--accent-gold);
      box-shadow: 0 0 0 3px rgba(17,17,17,0.9), 0 0 10px rgba(194,164,95,0.5);
      flex-shrink: 0;
    }

    /* ── Memory entry fade-in (enhanced with scale) ───── */
    .memory-entry {
      opacity: 0;
      transform: translateY(18px) scale(0.98);
      transition: opacity 0.7s ease, transform 0.7s cubic-bezier(0.25, 0.46, 0.45, 0.94);
    }
    .memory-entry.visible {
      opacity: 1;
      transform: translateY(0) scale(1);
    }

    /* ── Review sidebar entrance (desktop) ────────────── */
    .memory-entry .review-aside {
      opacity: 0;
      transform: translateX(12px);
      transition: opacity 0.5s ease 0.2s, transform 0.5s ease 0.2s;
    }
    .memory-entry.visible .review-aside {
      opacity: 1;
      transform: translateX(0);
    }

    /* ── Review mobile entrance ───────────────────────── */
    .memory-entry .review-mobile {
      opacity: 0;
      transform: translateY(8px);
      transition: opacity 0.45s ease 0.15s, transform 0.45s ease 0.15s;
    }
    .memory-entry.visible .review-mobile {
      opacity: 1;
      transform: translateY(0);
    }

    /* ── Frosted glass card ───────────────────────────── */
    .glass-card {
      background: rgba(17,17,17,0.7);
      backdrop-filter: blur(12px);
      -webkit-backdrop-filter: blur(12px);
      border: 1px solid rgba(194,164,95,0.18);
      border-radius: 1rem;
    }

    /* ── Media hover glow ─────────────────────────────── */
    .media-thumb {
      position: relative;
      overflow: hidden;
      border-radius: 0.75rem;
      cursor: pointer;
      transition: transform 0.3s ease, box-shadow 0.3s ease;
    }
    .media-thumb:hover {
      transform: scale(1.02);
      box-shadow: 0 0 20px rgba(194,164,95,0.25);
    }
    .media-thumb img,
    .media-thumb video {
      width: 100%;
      height: 100%;
      object-fit: cover;
      display: block;
    }
    .media-thumb .play-overlay {
      position: absolute;
      inset: 0;
      display: flex;
      align-items: center;
      justify-content: center;
      background: rgba(0,0,0,0.35);
      opacity: 0;
      transition: opacity 0.25s ease;
    }
    .media-thumb:hover .play-overlay { opacity: 1; }

    /* ── Review sidebar (desktop) ─────────────────────── */
    .review-aside {
      display: none;
    }
    @media (min-width: 768px) {
      .review-aside {
        display: block;
        width: 260px;
        flex-shrink: 0;
        align-self: flex-start;
        position: sticky;
        top: 6rem;
      }
    }

    /* ── Review pill (mobile) ─────────────────────────── */
    .review-mobile {
      display: block;
    }
    @media (min-width: 768px) {
      .review-mobile { display: none; }
    }

    /* ── Expand/collapse review ───────────────────────── */
    .review-full {
      display: none;
    }
    .review-full.open {
      display: block;
    }

    /* ── Decorative quote glyph ───────────────────────── */
    .review-quote-glyph {
      font-family: 'Cinzel', serif;
      font-size: 3rem;
      line-height: 1;
      color: var(--accent-gold);
      opacity: 0.2;
      user-select: none;
      pointer-events: none;
      display: block;
      margin-bottom: -0.75rem;
    }

    /* ── Page header shimmer ──────────────────────────── */
    @keyframes shimmer {
      0%   { background-position: -200% center; }
      100% { background-position:  200% center; }
    }
    .shimmer-text {
      background: linear-gradient(
        90deg,
        var(--accent-gold) 0%,
        #f5e9c8 40%,
        var(--accent-gold) 60%,
        var(--accent-gold-dark) 100%
      );
      background-size: 200% auto;
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
      animation: shimmer 5s linear infinite;
    }

    /* ── Mobile: treat entry like desktop mini (scale down, tap media to expand) ── */
    @media (max-width: 767px) {
      .entry-media-grid {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 0.5rem;
      }
      .entry-media-grid .video-cell {
        grid-column: 1 / -1;
      }
    }

    /* ── Subtle page grain overlay ───────────────────── */
    .grain-overlay {
      position: fixed;
      inset: 0;
      z-index: 0;
      pointer-events: none;
      opacity: 0.025;
      background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)'/%3E%3C/svg%3E");
      background-repeat: repeat;
      background-size: 128px;
    }
  </style>

  <!--
    transition:animate="none" prevents View Transitions from keeping these
    fixed background elements alive when navigating away from this page.
    Without this, they persist into other pages (e.g. the About page gets
    the grain overlay, starfield bleeds over everything).
  -->
  <div class="memories-bg" aria-hidden="true" transition:animate="none"></div>
  <div class="grain-overlay" aria-hidden="true" transition:animate="none"></div>
  <div id="starfield" class="memories-bg" aria-hidden="true" transition:animate="none"></div>

  <section class="relative z-10 mx-auto max-w-5xl px-4 py-12 text-ivory">

    <!-- Page Header -->
    <header class="mb-16 text-center">
      <h1 class="font-display text-4xl sm:text-5xl shimmer-text mb-3">Memories</h1>
      <p class="text-ivory/50 text-sm tracking-widest uppercase font-display">
        A living journal of performances
      </p>
      <div class="hr-gothic mt-6 max-w-xs mx-auto"></div>
    </header>

    {memoryRows.length === 0 ? (
      <p class="text-ivory/30 text-center italic py-24">
        No memories yet — check back soon.
      </p>
    ) : (
      <!-- Timeline -->
      <ol class="relative pl-8">
        <div class="timeline-line" aria-hidden="true"></div>

        {memoryRows.map((m, i) => (
          <li
            class="memory-entry relative mb-16 last:mb-0"
            style={`transition-delay: ${i * 120}ms`}
          >
            <div class="timeline-dot" aria-hidden="true"></div>

            <!-- Entry wrapper: flex row on desktop for sidebar review -->
            <div class="ml-6 flex gap-6 items-start">

              <!-- ── Main content column ── -->
              <div class="flex-1 min-w-0">

                <!-- Review snippet: mobile only, top of entry -->
                {m.review_body && (
                  <div class="review-mobile mb-4">
                    <button
                      class="review-toggle-mobile w-full text-left glass-card px-4 py-3 group"
                      aria-expanded="false"
                    >
                      <span class="review-quote-glyph">"</span>
                      <p class="text-ivory/70 text-sm italic leading-relaxed review-preview">
                        {truncate(m.review_body, 100)}
                      </p>
                      <p class="review-full text-ivory/70 text-sm italic leading-relaxed mt-2">
                        {m.review_body}
                      </p>
                      <div class="flex items-center justify-between mt-2">
                        <span class="text-gold font-display text-xs">{m.reviewer_name}</span>
                        <span class="review-toggle-label text-ivory/30 text-xs group-hover:text-gold transition">
                          read more ↓
                        </span>
                      </div>
                    </button>
                  </div>
                )}

                <!-- Entry header -->
                <div class="flex flex-wrap items-baseline gap-x-3 gap-y-1 mb-3">
                  <h2 class="font-display text-xl text-gold leading-snug">{m.title}</h2>
                  {m.event_date && (
                    <span
                      class="text-xs px-2 py-0.5 rounded-full font-display"
                      style="background: rgba(194,164,95,0.12); color: rgba(245,241,232,0.65); border: 1px solid rgba(194,164,95,0.25);"
                    >
                      {formatDate(m.event_date)}
                    </span>
                  )}
                  {m.location && (
                    <span class="text-ivory/50 text-sm">· {m.location}</span>
                  )}
                </div>

                <!-- Reflection -->
                {m.reflection && (
                  <p class="text-ivory/80 leading-relaxed mb-5 text-sm sm:text-base">
                    {m.reflection}
                  </p>
                )}

                <!-- Media grid -->
                {(m.video_src || (m.photo_urls && m.photo_urls.length > 0)) && (
                  <div class="entry-media-grid">

                    {m.video_src && (
                      <div class="video-cell">
                        <a
                          href={m.video_src}
                          class="media-thumb glightbox block aspect-video"
                          data-gallery={`memory-${m.id}`}
                          data-type="video"
                          data-description={m.title}
                          aria-label={`Watch video: ${m.title}`}
                        >
                          <video
                            src={m.video_src}
                            muted
                            preload="metadata"
                            class="w-full aspect-video object-cover rounded-xl"
                            aria-hidden="true"
                          ></video>
                          <div class="play-overlay rounded-xl">
                            <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="rgba(194,164,95,0.9)">
                              <circle cx="12" cy="12" r="11" fill="rgba(0,0,0,0.5)" stroke="rgba(194,164,95,0.6)" stroke-width="1"/>
                              <polygon points="10,8 18,12 10,16" fill="rgba(194,164,95,0.95)"/>
                            </svg>
                          </div>
                        </a>
                      </div>
                    )}

                    {m.photo_urls && m.photo_urls.slice(0, 4).map((src, pi) => (
                      <a
                        href={src}
                        class="media-thumb glightbox block aspect-square"
                        data-gallery={`memory-${m.id}`}
                        data-type="image"
                        aria-label={`Photo ${pi + 1}: ${m.title}`}
                      >
                        <img
                          src={src}
                          alt={`${m.title} photo ${pi + 1}`}
                          class="w-full h-full object-cover rounded-xl"
                          loading="lazy"
                        />
                      </a>
                    ))}

                  </div>
                )}

              </div>

              <!-- ── Review sidebar: desktop only ── -->
              {m.review_body && (
                <aside class="review-aside">
                  <div class="glass-card p-5 relative overflow-hidden">
                    <div
                      class="absolute -top-4 -right-2 text-8xl font-display leading-none select-none pointer-events-none"
                      style="color: var(--accent-gold); opacity: 0.07;"
                      aria-hidden="true"
                    >"</div>

                    <p
                      class="text-ivory/70 text-sm italic leading-relaxed mb-4 relative z-10 review-desktop-preview"
                    >
                      {truncate(m.review_body, 120)}
                    </p>

                    <p class="review-full text-ivory/70 text-sm italic leading-relaxed mb-4 relative z-10">
                      {m.review_body}
                    </p>

                    {m.review_body.length > 120 && (
                      <button
                        class="review-toggle-desktop text-gold/60 hover:text-gold text-xs font-display tracking-wide transition mb-3"
                        aria-expanded="false"
                      >
                        read more ↓
                      </button>
                    )}

                    <div class="border-t border-gold/20 pt-3 flex items-center justify-between gap-2">
                      <span class="font-display text-gold text-xs">{m.reviewer_name}</span>
                      <span
                        class="px-2 py-0.5 rounded-full text-xs"
                        style="background: rgba(194,164,95,0.1); color: rgba(245,241,232,0.5); border: 1px solid rgba(194,164,95,0.2);"
                      >
                        Verified Client
                      </span>
                    </div>
                  </div>
                </aside>
              )}

            </div>
          </li>
        ))}
      </ol>
    )}

    <!-- Bottom note -->
    <p class="text-ivory/20 text-xs text-center mt-20 font-display tracking-widest uppercase">
      More to come
    </p>

  </section>

  <!-- GLightbox JS -->
  <script src="https://cdnjs.cloudflare.com/ajax/libs/glightbox/3.2.0/js/glightbox.min.js"></script>

  <script>
    // ── Starfield ─────────────────────────────────────────
    function initStarfield() {
      const starfield = document.getElementById('starfield');
      if (!starfield) return;
      // Clear any existing stars (in case of re-init after navigation)
      starfield.innerHTML = '';
      const count = 80;
      for (let i = 0; i < count; i++) {
        const star = document.createElement('div');
        star.className = 'star';
        const size = Math.random() * 2 + 1;
        star.style.cssText = `
          width: ${size}px;
          height: ${size}px;
          left: ${Math.random() * 100}%;
          top: ${Math.random() * 100}%;
          --dur: ${3 + Math.random() * 5}s;
          --delay: ${Math.random() * 6}s;
          --min-op: ${0.05 + Math.random() * 0.1};
          --max-op: ${0.3 + Math.random() * 0.4};
        `;
        starfield.appendChild(star);
      }
    }

    // ── IntersectionObserver fade-in ──────────────────────
    function initMemoryObserver() {
      const entries = document.querySelectorAll('.memory-entry');
      if (!entries.length) return;

      const observer = new IntersectionObserver(
        (obs) => {
          obs.forEach(entry => {
            if (entry.isIntersecting) {
              entry.target.classList.add('visible');
              observer.unobserve(entry.target);
            }
          });
        },
        { threshold: 0.08 }
      );
      entries.forEach(el => observer.observe(el));
    }

    // ── GLightbox init ────────────────────────────────────
    function initLightbox() {
      // @ts-ignore
      if (typeof GLightbox !== 'undefined') {
        // @ts-ignore
        GLightbox({
          selector: '.glightbox',
          touchNavigation: true,
          loop: false,
          autoplayVideos: true,
          skin: 'clean',
        });
      }
    }

    // ── Desktop review expand/collapse ───────────────────
    function initReviewToggles() {
      document.querySelectorAll('.review-toggle-desktop').forEach(btn => {
        btn.addEventListener('click', () => {
          const aside = btn.closest('aside') as HTMLElement;
          const preview = aside.querySelector('.review-desktop-preview') as HTMLElement;
          const full = aside.querySelector('.review-full') as HTMLElement;
          const expanded = btn.getAttribute('aria-expanded') === 'true';

          if (expanded) {
            preview.style.display = '';
            full.classList.remove('open');
            btn.textContent = 'read more ↓';
            btn.setAttribute('aria-expanded', 'false');
          } else {
            preview.style.display = 'none';
            full.classList.add('open');
            btn.textContent = 'show less ↑';
            btn.setAttribute('aria-expanded', 'true');
          }
        });
      });

      document.querySelectorAll('.review-toggle-mobile').forEach(btn => {
        btn.addEventListener('click', () => {
          const preview = btn.querySelector('.review-preview') as HTMLElement;
          const full = btn.querySelector('.review-full') as HTMLElement;
          const label = btn.querySelector('.review-toggle-label') as HTMLElement;
          const expanded = btn.getAttribute('aria-expanded') === 'true';

          if (expanded) {
            preview.style.display = '';
            full.classList.remove('open');
            label.textContent = 'read more ↓';
            btn.setAttribute('aria-expanded', 'false');
          } else {
            preview.style.display = 'none';
            full.classList.add('open');
            label.textContent = 'show less ↑';
            btn.setAttribute('aria-expanded', 'true');
          }
        });
      });
    }

    // Run on first direct load
    initStarfield();
    initMemoryObserver();
    initLightbox();
    initReviewToggles();

    // Re-run everything after View Transitions navigation to this page
    document.addEventListener('astro:page-load', () => {
      initStarfield();
      initMemoryObserver();
      initLightbox();
      initReviewToggles();
    });
  </script>
</BaseLayout>