---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Divider from "../../components/Divider.astro";
import YouTubeFacade from "../../components/YouTubeFacade.astro";
import InstrumentChat from "../../components/InstrumentChat.astro";

// ✅ SEO
const title = "My Instruments — Tradscendence | Sound Beyond Borders";
const description =
  "Browse Hunter Eastland's world & folk instruments. Hear quick audio teasers and jump to pages: Surbahar, Oud, Saz, Rabab, Esraj, Duduk, Tar, and more.";

/** Latest YouTube embed (manual) */
const LATEST_YT = {
  id: "OUpYRKzTAhM",
  si: "Vh8olflrhQvMtgcs",
  isShort: false,
  title: "My latest performance",
  instrumentLink: "/instruments/CumbusOud",
};

const watchUrl = `https://youtu.be/${LATEST_YT.id}`;

import { neon } from "@neondatabase/serverless";

const sql = neon(import.meta.env.DATABASE_URL);
const dbItems = await sql`
  SELECT slug, name, audio_teaser, page_ready
  FROM instruments
  ORDER BY display_order ASC
`;

const items = dbItems.map((row) => ({
  name: row.name,
  file: row.audio_teaser,
  href: row.page_ready ? `/instruments/${row.slug}` : "/coming-soon",
}));
---

<BaseLayout {title} description={description} canonical="https://www.soundbeyondborders.com/instruments/">

  <!-- BR-007 fix: audio unlock toast (desktop only) -->
  <div
    id="audio-unlock-toast"
    class="fixed bottom-20 left-1/2 -translate-x-1/2 z-50 px-4 py-2 rounded-xl text-sm font-medium border border-gold/40 bg-charcoal/90 text-ivory/80 shadow-lg backdrop-blur-sm transition-opacity duration-500 pointer-events-none md:block hidden"
    aria-live="polite"
  >
    👆 Click anywhere to enable audio previews
  </div>

  <section class="instruments-page mx-auto max-w-6xl px-4 py-10 space-y-6">
    <h1 class="font-display text-3xl">My Instruments</h1>
    <p class="opacity-80">
      Instruments that I've collected and learned to play over the years. Hit the play
      button to <b>hear</b> a quick teaser that I made! Clicking the instrument's name sends
      you to the instrument's page. I hope you find a sound that you like! :)
    </p>

    <ul class="grid gap-4 sm:grid-cols-2 md:grid-cols-3">
      {items.map(({ name, file, href }) => (
        <li class="frame rounded-xl p-3 flex items-center justify-between">
          <a class="gothic-link" href={href}>{name}</a>
          <button
            type="button"
            class="play-btn opacity-60 hover:opacity-100 transition"
            data-audio={file}
            aria-label={`Play ${name} sample`}
          >
            ▶︎
          </button>
        </li>
      ))}
    </ul>
  </section>
<InstrumentChat
  pageContext="Instruments index page — visitor is browsing all available instruments including Surbahar, Baglama Saz, Arabic Oud, Duduk, Esraj, Setar, Rabab, and more"
  suggestedQuestions={[
    "Which of these instruments is hardest to learn?",
    "What do the Surbahar and Baglama Saz have in common?",
    "Tell me about the Armenian Duduk",
    "Which instruments here share Middle Eastern roots?",
  ]}
/>
  <Divider />

  <!-- Latest YouTube video (bottom of page, above footer) -->
  <section id="latest-video" class="mx-auto max-w-6xl px-4 pb-10 scroll-mt-24">
    <h2 class="font-display text-xl sm:text-2xl mb-3 sm:mb-4">
      My Latest Youtube Upload!
    </h2>

    <figure class="space-y-3">
      <div class="relative rounded-2xl overflow-hidden frame shadow-soft p-[2px] bg-gradient-to-r from-[#C2A45F] via-[#A8743D] to-[#6E2A2A]">
        <div class={`relative w-full ${LATEST_YT.isShort ? 'aspect-[9/16]' : 'aspect-video'} rounded-[14px] overflow-hidden`}>
          <YouTubeFacade
            videoId={LATEST_YT.id}
            siParam={LATEST_YT.si}
            title={LATEST_YT.title}
            isShort={LATEST_YT.isShort}
            class="absolute inset-0 rounded-[12px]"
          />
        </div>
      </div>

      <figcaption class="text-sm opacity-80 flex flex-col sm:flex-row sm:items-center sm:gap-3">
        <span class="font-display">{LATEST_YT.title}</span>
        <a href={watchUrl} target="_blank" rel="noopener" class="gothic-link font-bold">
          Watch on YouTube →
        </a>
      </figcaption>
    </figure>

    <div class="pt-4">
      <a
        href={LATEST_YT.instrumentLink ?? '/instruments'}
        class="group gothic-link font-bold inline-flex items-center gap-1 drop-shadow-[0_0_2px_ivory]">
        <span>Explore this instrument more</span>
        <span aria-hidden="true" class="transition-transform group-hover:translate-x-0.5">→</span>
      </a>
    </div>
  </section>

  <script>
    document.addEventListener('DOMContentLoaded', () => {
      const supportsHover = window.matchMedia('(hover: hover)').matches;

      // BR-007 fix: show unlock toast on desktop hover-capable devices,
      // dismiss and unlock audio policy on first click
      const toast = document.getElementById('audio-unlock-toast');
      let audioUnlocked = false;

      if (supportsHover && toast) {
        toast.style.opacity = '1';

        document.addEventListener('click', () => {
          if (audioUnlocked) return;
          audioUnlocked = true;

          // Actually unlock the browser's audio policy via AudioContext
          // This allows hover-to-play to work immediately after this click
          try {
            const ctx = new (window.AudioContext || (window as any).webkitAudioContext)();
            ctx.resume().then(() => ctx.close());
          } catch {}

          // Fade out and remove toast
          toast.style.opacity = '0';
          setTimeout(() => toast.remove(), 500);
        }, { once: true });
      }

      const players = new Map<string, HTMLAudioElement>();
      let current: HTMLAudioElement | null = null;

      function getPlayer(src: string): HTMLAudioElement {
        if (!players.has(src)) {
          const a = new Audio(src);
          a.preload = 'none';
          players.set(src, a);
        }
        return players.get(src)!;
      }

      function stopCurrent() {
        if (current && !current.paused) {
          current.pause();
          current.currentTime = 0;
        }
      }

      async function play(src: string) {
        stopCurrent();
        const a = getPlayer(src);
        current = a;
        a.currentTime = 0;
        a.volume = 0.9;
        try {
          await a.play();
        } catch (err) {
          // Autoplay blocked or AbortError on rapid switching — fail silently
        }
      }

      document.querySelectorAll('[data-audio]').forEach((btn) => {
        const src = btn.getAttribute('data-audio');
        if (!src) return;

        btn.addEventListener('click', () => play(src), { passive: true });

        if (supportsHover) {
          btn.addEventListener('mouseenter', () => play(src));
          btn.addEventListener('mouseleave', () => stopCurrent());
          btn.addEventListener('blur', () => stopCurrent());
        }
      });

      document.addEventListener('visibilitychange', () => {
        if (document.hidden) stopCurrent();
      });
    });
  </script>

  <style is:global>
    html { scroll-behavior: smooth; }
    #latest-video { scroll-margin-top: 96px; }
  </style>

  <style>
    #audio-unlock-toast {
      opacity: 0;
    }

    .instruments-page ul li.frame {
      position: relative;
      background: linear-gradient(to right, rgba(205, 127, 50, 0.15), transparent);
      border-radius: 0.75rem;
      overflow: hidden;
    }

    .instruments-page ul li.frame::before {
      content: "";
      position: absolute;
      inset: 0;
      border-radius: inherit;
      padding: 1px;
      background: linear-gradient(to right, rgba(205, 127, 50, 0.8), transparent);
      -webkit-mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
      -webkit-mask-composite: xor;
              mask-composite: exclude;
      pointer-events: none;
    }

    /* Play button — base */
    .instruments-page button[data-audio] {
      font-size: 1.75rem;
      color: var(--accent-gold, #C2A45F);
      text-shadow:
        2px 0 var(--bronze, #CD7F32),
       -2px 0 var(--bronze, #CD7F32),
        0 2px var(--bronze, #CD7F32),
        0 -2px var(--bronze, #CD7F32),
        2px 2px var(--bronze, #CD7F32),
       -3px -3px var(--bronze, #CD7F32),
        2px -2px var(--bronze, #CD7F32),
       -3px 3px var(--bronze, #CD7F32);
      /* Transitions for opacity (Tailwind), lift, and glow */
      transition: opacity 0.15s ease, transform 0.2s ease, filter 0.2s ease;
    }

    /* Play button — hover: lift + soft gold glow */
    .instruments-page button[data-audio]:hover {
      transform: translateY(-2px);
      filter: drop-shadow(0 0 7px rgba(194, 164, 95, 0.75))
              drop-shadow(0 0 14px rgba(194, 164, 95, 0.35));
    }
  </style>
</BaseLayout>