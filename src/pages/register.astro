---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Create Account — Tradscendence" description="Create your Tradscendence account to track your booking inquiries.">
  <section class="mx-auto max-w-md px-4 py-16 sm:py-24">

    <h1 id="authHeading" class="font-display text-3xl text-gold text-center mb-2">Create Account</h1>
    <p id="authSubtext" class="text-ivory/60 text-center text-sm mb-8">
      Set up your account to track your booking inquiries.
    </p>

    <div id="statusMsg" class="hidden mb-6 rounded-xl px-4 py-3 text-sm border border-gold/40 bg-gold/10 text-ivory" role="alert"></div>

    <!-- ─── Login Form (hidden by default) ─────────────── -->
    <form id="loginForm" class="hidden flex flex-col gap-4" novalidate>
      <input type="hidden" name="redirect" value="/dashboard" />

      <label class="flex flex-col gap-1">
        <span class="text-ivory/80 text-sm font-display">Email</span>
        <input
          type="email"
          name="email"
          required
          autocomplete="email"
          class="bg-ebony/60 frame rounded-xl px-3 py-2 border border-[var(--accent-bronze)] text-ivory placeholder:text-ivory/30 focus:outline-none focus:border-gold"
          placeholder="you@example.com"
        />
      </label>

      <label class="flex flex-col gap-1">
        <span class="text-ivory/80 text-sm font-display">Password</span>
        <div class="relative">
          <input
            type="password"
            name="password"
            required
            autocomplete="current-password"
            class="w-full bg-ebony/60 frame rounded-xl px-3 py-2 pr-10 border border-[var(--accent-bronze)] text-ivory placeholder:text-ivory/30 focus:outline-none focus:border-gold"
            placeholder="••••••••"
          />
          <button type="button" class="toggle-password absolute right-3 top-1/2 -translate-y-1/2 text-ivory/40 hover:text-gold transition" aria-label="Show password">
            <svg class="eye-open w-5 h-5" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M2.036 12.322a1.012 1.012 0 010-.639C3.423 7.51 7.36 4.5 12 4.5c4.638 0 8.573 3.007 9.963 7.178.07.207.07.431 0 .639C20.577 16.49 16.64 19.5 12 19.5c-4.638 0-8.573-3.007-9.963-7.178z"/><path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
            <svg class="eye-closed w-5 h-5 hidden" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M3.98 8.223A10.477 10.477 0 001.934 12c1.292 4.338 5.31 7.5 10.066 7.5.993 0 1.953-.138 2.863-.395M6.228 6.228A10.45 10.45 0 0112 4.5c4.756 0 8.773 3.162 10.065 7.498a10.523 10.523 0 01-4.293 5.774M6.228 6.228L3 3m3.228 3.228l3.65 3.65m7.894 7.894L21 21m-3.228-3.228l-3.65-3.65m0 0a3 3 0 10-4.243-4.243m4.242 4.242L9.88 9.88"/></svg>
          </button>
        </div>
      </label>

      <button
        type="submit"
        class="rounded-xl px-4 py-2 bg-gold text-ivory hover:bg-golddark hover:text-rosewood font-semibold frame transition-colors mt-2"
      >
        Sign In
      </button>
    </form>

    <!-- ─── Register Form (shown by default) ───────────── -->
    <form id="registerForm" class="flex flex-col gap-4" novalidate>
      <div class="grid grid-cols-2 gap-3">
        <label class="flex flex-col gap-1">
          <span class="text-ivory/80 text-sm font-display">First Name *</span>
          <input
            type="text"
            name="firstName"
            required
            autocomplete="given-name"
            class="bg-ebony/60 frame rounded-xl px-3 py-2 border border-[var(--accent-bronze)] text-ivory placeholder:text-ivory/30 focus:outline-none focus:border-gold"
            placeholder="Hunter"
          />
        </label>

        <label class="flex flex-col gap-1">
          <span class="text-ivory/80 text-sm font-display">Last Name</span>
          <input
            type="text"
            name="lastName"
            autocomplete="family-name"
            class="bg-ebony/60 frame rounded-xl px-3 py-2 border border-[var(--accent-bronze)] text-ivory placeholder:text-ivory/30 focus:outline-none focus:border-gold"
            placeholder="Eastland"
          />
        </label>
      </div>

      <label class="flex flex-col gap-1">
        <span class="text-ivory/80 text-sm font-display">Email *</span>
        <input
          type="email"
          name="email"
          required
          autocomplete="email"
          class="bg-ebony/60 frame rounded-xl px-3 py-2 border border-[var(--accent-bronze)] text-ivory placeholder:text-ivory/30 focus:outline-none focus:border-gold"
          placeholder="you@example.com"
        />
      </label>

      <label class="flex flex-col gap-1">
        <span class="text-ivory/80 text-sm font-display">Password *</span>
        <div class="relative">
          <input
            type="password"
            name="password"
            required
            autocomplete="new-password"
            minlength="8"
            class="w-full bg-ebony/60 frame rounded-xl px-3 py-2 pr-10 border border-[var(--accent-bronze)] text-ivory placeholder:text-ivory/30 focus:outline-none focus:border-gold"
            placeholder="At least 8 characters"
          />
          <button type="button" class="toggle-password absolute right-3 top-1/2 -translate-y-1/2 text-ivory/40 hover:text-gold transition" aria-label="Show password">
            <svg class="eye-open w-5 h-5" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M2.036 12.322a1.012 1.012 0 010-.639C3.423 7.51 7.36 4.5 12 4.5c4.638 0 8.573 3.007 9.963 7.178.07.207.07.431 0 .639C20.577 16.49 16.64 19.5 12 19.5c-4.638 0-8.573-3.007-9.963-7.178z"/><path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
            <svg class="eye-closed w-5 h-5 hidden" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M3.98 8.223A10.477 10.477 0 001.934 12c1.292 4.338 5.31 7.5 10.066 7.5.993 0 1.953-.138 2.863-.395M6.228 6.228A10.45 10.45 0 0112 4.5c4.756 0 8.773 3.162 10.065 7.498a10.523 10.523 0 01-4.293 5.774M6.228 6.228L3 3m3.228 3.228l3.65 3.65m7.894 7.894L21 21m-3.228-3.228l-3.65-3.65m0 0a3 3 0 10-4.243-4.243m4.242 4.242L9.88 9.88"/></svg>
          </button>
        </div>
      </label>

      <label class="flex flex-col gap-1">
        <span class="text-ivory/80 text-sm font-display">Confirm Password *</span>
        <div class="relative">
          <input
            type="password"
            name="confirmPassword"
            required
            autocomplete="new-password"
            class="w-full bg-ebony/60 frame rounded-xl px-3 py-2 pr-10 border border-[var(--accent-bronze)] text-ivory placeholder:text-ivory/30 focus:outline-none focus:border-gold"
            placeholder="••••••••"
          />
          <button type="button" class="toggle-password absolute right-3 top-1/2 -translate-y-1/2 text-ivory/40 hover:text-gold transition" aria-label="Show password">
            <svg class="eye-open w-5 h-5" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M2.036 12.322a1.012 1.012 0 010-.639C3.423 7.51 7.36 4.5 12 4.5c4.638 0 8.573 3.007 9.963 7.178.07.207.07.431 0 .639C20.577 16.49 16.64 19.5 12 19.5c-4.638 0-8.573-3.007-9.963-7.178z"/><path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
            <svg class="eye-closed w-5 h-5 hidden" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M3.98 8.223A10.477 10.477 0 001.934 12c1.292 4.338 5.31 7.5 10.066 7.5.993 0 1.953-.138 2.863-.395M6.228 6.228A10.45 10.45 0 0112 4.5c4.756 0 8.773 3.162 10.065 7.498a10.523 10.523 0 01-4.293 5.774M6.228 6.228L3 3m3.228 3.228l3.65 3.65m7.894 7.894L21 21m-3.228-3.228l-3.65-3.65m0 0a3 3 0 10-4.243-4.243m4.242 4.242L9.88 9.88"/></svg>
          </button>
        </div>
      </label>

      <button
        type="submit"
        class="rounded-xl px-4 py-2 bg-gold text-ivory hover:bg-golddark hover:text-rosewood font-semibold frame transition-colors mt-2"
      >
        Create Account
      </button>
    </form>

    <!-- Toggle link -->
    <p class="text-center text-sm text-ivory/50 mt-6">
      <span id="toggleText">Already have an account?</span>
      <button id="toggleBtn" type="button" class="gothic-link text-gold hover:text-rosewood ml-1">
        Sign in
      </button>
    </p>

  </section>
</BaseLayout>

<script>
  const loginForm = document.getElementById('loginForm') as HTMLFormElement;
  const registerForm = document.getElementById('registerForm') as HTMLFormElement;
  const toggleBtn = document.getElementById('toggleBtn')!;
  const toggleText = document.getElementById('toggleText')!;
  const heading = document.getElementById('authHeading')!;
  const subtext = document.getElementById('authSubtext')!;
  const statusMsg = document.getElementById('statusMsg')!;

  let isLogin = false; // Start in register mode

  toggleBtn.addEventListener('click', () => {
    isLogin = !isLogin;
    loginForm.classList.toggle('hidden', !isLogin);
    registerForm.classList.toggle('hidden', isLogin);
    heading.textContent = isLogin ? 'Sign In' : 'Create Account';
    subtext.textContent = isLogin
      ? 'Enter your credentials to view your bookings.'
      : 'Set up your account to track your booking inquiries.';
    toggleText.textContent = isLogin ? "Don't have an account?" : 'Already have an account?';
    toggleBtn.textContent = isLogin ? 'Create one' : 'Sign in';
    statusMsg.classList.add('hidden');
  });

  function showStatus(msg: string, isError = false) {
    statusMsg.textContent = msg;
    statusMsg.classList.remove('hidden');
    if (isError) {
      statusMsg.classList.add('border-rosewood/60', 'bg-rosewood/10');
      statusMsg.classList.remove('border-gold/40', 'bg-gold/10');
    } else {
      statusMsg.classList.remove('border-rosewood/60', 'bg-rosewood/10');
      statusMsg.classList.add('border-gold/40', 'bg-gold/10');
    }
  }

  // ── Password visibility toggles ────────────────────────
  document.querySelectorAll('.toggle-password').forEach((btn) => {
    btn.addEventListener('click', () => {
      const input = btn.parentElement?.querySelector('input') as HTMLInputElement;
      const eyeOpen = btn.querySelector('.eye-open') as SVGElement;
      const eyeClosed = btn.querySelector('.eye-closed') as SVGElement;
      if (!input || !eyeOpen || !eyeClosed) return;

      const isHidden = input.type === 'password';
      input.type = isHidden ? 'text' : 'password';
      eyeOpen.classList.toggle('hidden', isHidden);
      eyeClosed.classList.toggle('hidden', !isHidden);
      (btn as HTMLButtonElement).setAttribute('aria-label', isHidden ? 'Hide password' : 'Show password');
    });
  });

  async function handleSubmit(e: SubmitEvent, endpoint: string) {
    e.preventDefault();
    const form = e.target as HTMLFormElement;
    const data = Object.fromEntries(new FormData(form));
    const btn = form.querySelector('button[type="submit"]') as HTMLButtonElement;

    if (!isLogin) {
      if (data.password !== data.confirmPassword) {
        showStatus('Passwords do not match.', true);
        return;
      }
    }

    btn.disabled = true;
    btn.textContent = isLogin ? 'Signing in…' : 'Creating account…';

    try {
      const payload: Record<string, unknown> = { email: data.email, password: data.password };

      // Include name fields for registration
      if (!isLogin) {
        payload.firstName = data.firstName;
        payload.lastName = data.lastName || '';
      }

      const res = await fetch(endpoint, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload),
      });

      const result = await res.json();

      if (!res.ok) {
        showStatus(result.error || 'Something went wrong.', true);
        btn.disabled = false;
        btn.textContent = isLogin ? 'Sign In' : 'Create Account';
        return;
      }

      if (result.skipOtp) {
        window.location.href = '/dashboard';
        return;
      }

      const email = encodeURIComponent(result.email || data.email);
      window.location.href = `/verify?email=${email}&redirect=${encodeURIComponent('/dashboard')}`;
    } catch {
      showStatus('Network error — please try again.', true);
      btn.disabled = false;
      btn.textContent = isLogin ? 'Sign In' : 'Create Account';
    }
  }

  loginForm.addEventListener('submit', (e) => handleSubmit(e, '/api/auth/login'));
  registerForm.addEventListener('submit', (e) => handleSubmit(e, '/api/auth/register'));
</script>