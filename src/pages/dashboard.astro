---
import BaseLayout from "../layouts/BaseLayout.astro";
import { neon } from "@neondatabase/serverless";

const user = Astro.locals.user;

if (!user) {
  return Astro.redirect("/login");
}

let submissions: any[] = [];
let contracts: Record<number, any> = {};
let invoices: Record<number, any[]> = {};
let reviews: Record<number, any> = {};
let userProfile: { first_name: string | null; last_name: string | null; prefix: string | null } = {
  first_name: null,
  last_name: null,
  prefix: null,
};

if (!import.meta.env.DEV && import.meta.env.DATABASE_URL) {
  const sql = neon(import.meta.env.DATABASE_URL);

  const [profileResult, submissionResult] = await Promise.all([
    sql`SELECT first_name, last_name, prefix FROM users WHERE id = ${user.id}`,
    sql`
      SELECT 
        id, first_name, last_name, email, event_date, location, 
        instruments, message, status, created_at
      FROM contact_submissions
      WHERE email = ${user.email}
      ORDER BY created_at DESC
    `,
  ]);

  if (profileResult.length > 0) {
    userProfile = profileResult[0] as typeof userProfile;
  }

  submissions = submissionResult;

  if (submissions.length > 0) {
    const submissionIds = submissions.map(s => s.id);

    const [contractResults, invoiceResults, reviewResults] = await Promise.all([
      sql`
        SELECT submission_id, id, file_url, uploaded_at, signed_at, signature_name
        FROM contracts
        WHERE submission_id = ANY(${submissionIds})
      `,
      sql`
        SELECT id, submission_id, file_url, label, uploaded_at
        FROM invoices
        WHERE submission_id = ANY(${submissionIds})
        ORDER BY submission_id, uploaded_at ASC
      `,
      sql`
        SELECT submission_id, id, body, approved, created_at
        FROM reviews
        WHERE submission_id = ANY(${submissionIds})
      `,
    ]);

    contractResults.forEach(c => {
      contracts[c.submission_id] = c;
    });
    invoiceResults.forEach(inv => {
      if (!invoices[inv.submission_id]) invoices[inv.submission_id] = [];
      invoices[inv.submission_id].push(inv);
    });
    reviewResults.forEach(r => {
      reviews[r.submission_id] = r;
    });
  }
}

// ── Greeting logic ──────────────────────────────────────
const needsProfile = !userProfile.last_name || !userProfile.prefix;
let greeting = '';

if (userProfile.prefix && userProfile.last_name) {
  if (userProfile.prefix === 'none') {
    const initial = (userProfile.first_name || user.email)[0].toUpperCase();
    greeting = `Welcome back, ${initial}. ${userProfile.last_name}`;
  } else {
    greeting = `Welcome back, ${userProfile.prefix} ${userProfile.last_name}`;
  }
} else if (userProfile.first_name) {
  greeting = `Welcome back, ${userProfile.first_name}`;
} else {
  greeting = `Welcome back`;
}

// ── Status display config ───────────────────────────────
const statusConfig: Record<string, { label: string; classes: string }> = {
  "Pending":          { label: "Pending",           classes: "bg-gold/20 text-gold border-gold/40" },
  "Reviewing":        { label: "Reviewing",          classes: "bg-blue-500/20 text-blue-400 border-blue-500/40" },
  "Contract Sent":    { label: "Contract Sent",      classes: "bg-purple-500/20 text-purple-400 border-purple-500/40" },
  "Contract Signed":  { label: "Contract Signed",    classes: "bg-cyan-500/20 text-cyan-400 border-cyan-500/40" },
  "Invoice Sent":     { label: "Invoice Sent",       classes: "bg-orange-500/20 text-orange-400 border-orange-500/40" },
  "Payment Received": { label: "Booking Confirmed",  classes: "bg-green-500/20 text-green-400 border-green-500/40" },
  "Complete":         { label: "Complete",           classes: "bg-emerald-500/20 text-emerald-400 border-emerald-500/40" },
  "Declined":         { label: "Declined",           classes: "bg-rosewood/20 text-rosewood border-rosewood/40" },
};

function getStatusConfig(status: string) {
  return statusConfig[status] ?? statusConfig["Pending"];
}
---

<BaseLayout
  title="My Account — Tradscendence"
  description="View your booking inquiries and contracts"
  canonical={`${Astro.url.origin}/dashboard`}
>
  <div class="min-h-screen bg-charcoal text-ivory px-4 py-8">
    <div class="max-w-7xl mx-auto">
      <div class="flex flex-col lg:flex-row gap-8">

        <!-- Sidebar -->
        <aside class="lg:w-64 shrink-0">
          <div class="bg-charcoal/80 frame rounded-xl p-6 sticky top-20">
            <h2 class="font-display text-xl text-gold mb-4">My Account</h2>

            <div class="mb-4 pb-4 border-b border-gold/20 lg:hidden">
              <button
                id="logoutBtnMobile"
                class="w-full px-4 py-2 rounded-xl bg-rosewood/20 text-rosewood hover:bg-rosewood hover:text-ivory font-semibold frame transition"
              >
                Sign Out
              </button>
            </div>

            <nav class="space-y-2">
              <a href="#bookings" class="block px-3 py-2 rounded-lg bg-gold/10 text-gold font-semibold">
                Booking Inquiries
              </a>
            </nav>

            <div class="mt-8 pt-6 border-t border-gold/20 hidden lg:block">
              <button
                id="logoutBtn"
                class="w-full px-4 py-2 rounded-xl bg-rosewood/20 text-rosewood hover:bg-rosewood hover:text-ivory font-semibold frame transition"
              >
                Sign Out
              </button>
            </div>
          </div>
        </aside>

        <!-- Main Content -->
        <main class="flex-1">
          <div class="mb-8">
            <h1 class="font-display text-3xl md:text-4xl text-gold mb-2">
              {greeting}
            </h1>
            <p class="text-ivory/70">Manage your booking inquiries and documents</p>
          </div>

          <!-- Profile Completion Card -->
          {needsProfile && (
            <section id="profileCard" class="mb-8 bg-gold/5 border border-gold/40 rounded-xl p-6 frame">
              <h2 class="font-display text-xl text-gold mb-2">Complete Your Profile</h2>
              <p class="text-ivory/70 text-sm mb-5">
                Help us greet you properly — choose how you'd like to be addressed.
              </p>
              <form id="profileForm" class="space-y-4">
                <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                  <label class="flex flex-col gap-1">
                    <span class="text-ivory/80 text-sm font-display">First Name *</span>
                    <input
                      type="text"
                      name="firstName"
                      required
                      value={userProfile.first_name || ''}
                      class="bg-ebony/60 frame rounded-xl px-3 py-2 border border-[var(--accent-bronze)] text-ivory placeholder:text-ivory/30 focus:outline-none focus:border-gold"
                    />
                  </label>
                  <label class="flex flex-col gap-1">
                    <span class="text-ivory/80 text-sm font-display">Last Name *</span>
                    <input
                      type="text"
                      name="lastName"
                      required
                      value={userProfile.last_name || ''}
                      class="bg-ebony/60 frame rounded-xl px-3 py-2 border border-[var(--accent-bronze)] text-ivory placeholder:text-ivory/30 focus:outline-none focus:border-gold"
                    />
                  </label>
                </div>
                <label class="flex flex-col gap-1">
                  <span class="text-ivory/80 text-sm font-display">Preferred Name <span class="text-ivory/40 font-sans text-xs">(optional)</span></span>
                  <p class="text-ivory/40 text-xs mb-1">This is only so I know how to refer to you in future messages or phone calls.</p>
                  <input
                    type="text"
                    name="preferredName"
                    class="bg-ebony/60 frame rounded-xl px-3 py-2 border border-[var(--accent-bronze)] text-ivory placeholder:text-ivory/30 focus:outline-none focus:border-gold"
                    placeholder="e.g., Bobby, Liz, etc."
                  />
                </label>

                {!userProfile.prefix && (
                  <label class="flex flex-col gap-1 max-w-[220px]">
                    <span class="text-ivory/80 text-sm font-display">How would you like to be addressed?</span>
                    <select
                      name="prefix"
                      required
                      class="bg-charcoal frame rounded-xl px-3 py-2 border border-[var(--accent-bronze)] text-ivory focus:outline-none focus:border-gold appearance-none"
                      style="background-image: url('data:image/svg+xml;charset=UTF-8,%3Csvg%20xmlns%3D%22http%3A%2F%2Fwww.w3.org%2F2000%2Fsvg%22%20width%3D%2212%22%20height%3D%2212%22%20viewBox%3D%220%200%2024%2024%22%20fill%3D%22none%22%20stroke%3D%22%23C2A45F%22%20stroke-width%3D%222%22%3E%3Cpath%20d%3D%22M6%209l6%206%206-6%22%2F%3E%3C%2Fsvg%3E'); background-repeat: no-repeat; background-position: right 0.75rem center;"
                    >
                      <option value="" disabled selected class="bg-[#111] text-ivory">Select a prefix</option>
                      <option value="Mr." class="bg-[#111] text-ivory">Mr.</option>
                      <option value="Mrs." class="bg-[#111] text-ivory">Mrs.</option>
                      <option value="Ms." class="bg-[#111] text-ivory">Ms.</option>
                      <option value="none" class="bg-[#111] text-ivory">Prefer not to disclose</option>
                    </select>
                  </label>
                )}

                <div class="flex items-center gap-4">
                  <button
                    type="submit"
                    id="profileSaveBtn"
                    class="rounded-xl px-6 py-2 bg-gold text-ivory hover:bg-gold-dark hover:text-rosewood font-semibold frame transition"
                  >
                    Save
                  </button>
                  <p id="profileError" class="text-rosewood text-sm hidden"></p>
                  <p id="profileSuccess" class="text-green-400 text-sm hidden"></p>
                </div>
              </form>
            </section>
          )}

          <!-- Bookings Section -->
          <section id="bookings" class="scroll-mt-28 space-y-6">
            {submissions.length === 0 ? (
              <!-- ═══ ENHANCED: Zero-bookings empty state ═══ -->
              <div class="bg-charcoal/80 frame rounded-xl p-10 text-center max-w-lg mx-auto">
                <div class="mb-5 flex items-center justify-center gap-4 opacity-40">
                  <span class="block h-px w-10 bg-gradient-to-r from-transparent to-[var(--bronze)]"></span>
                  <span class="text-[var(--accent-gold)] text-lg">♪</span>
                  <span class="block h-px w-10 bg-gradient-to-l from-transparent to-[var(--bronze)]"></span>
                </div>
                <h3 class="font-display text-xl text-gold mb-3">No Bookings Yet</h3>
                <p class="text-ivory/60 text-sm leading-relaxed mb-6">
                  Once you submit a booking inquiry, it will appear here along with
                  any contracts, invoices, and documents related to your event.
                </p>
                <a
                  href="/contact"
                  class="inline-block rounded-xl px-6 py-3 bg-gold text-ivory hover:bg-gold-dark hover:text-rosewood font-semibold frame transition"
                >
                  Submit an Inquiry
                </a>
                <p class="text-ivory/30 text-xs mt-4">
                  Questions? Feel free to <a href="/contact" class="text-gold/60 hover:text-gold underline underline-offset-2">reach out</a> anytime.
                </p>
              </div>
            ) : (
              submissions.map((sub, cardIndex) => {
                const contract = contracts[sub.id];
                const subInvoices = invoices[sub.id] || [];
                const existingReview = reviews[sub.id] ?? null;
                const isComplete = sub.status === "Complete";
                const hasNoDocuments = !contract && subInvoices.length === 0;
                const { label: statusLabel, classes: statusClasses } = getStatusConfig(sub.status);
                return (
                  <article class="bg-charcoal/80 frame rounded-xl p-6 card-enter" data-submission-id={sub.id} style={`transition-delay: ${cardIndex * 100}ms`}>

                    <!-- Header -->
                    <div class="flex flex-wrap items-start justify-between gap-4 mb-4">
                      <div>
                        <h3 class="font-display text-xl text-gold mb-1">
                          {sub.location || "Booking Inquiry"}
                        </h3>
                        {sub.event_date && (
                          <p class="text-ivory/60 text-sm">
                            Event Date: {new Date(sub.event_date).toLocaleDateString()}
                          </p>
                        )}
                        <p class="text-ivory/60 text-sm">
                          Submitted: {new Date(sub.created_at).toLocaleDateString()}
                        </p>
                      </div>
                      <span class={`px-3 py-1 rounded-lg border text-sm font-semibold ${statusClasses}`}>
                        {statusLabel}
                      </span>
                    </div>

                    <!-- Details -->
                    <div class="grid md:grid-cols-2 gap-4 mb-4 text-sm">
                      {sub.instruments && sub.instruments.length > 0 && (
                        <div>
                          <span class="text-gold font-semibold">Instruments:</span>
                          <span class="text-ivory/80 ml-2">{sub.instruments.join(", ")}</span>
                        </div>
                      )}
                      {sub.message && (
                        <div class="md:col-span-2">
                          <span class="text-gold font-semibold">Message:</span>
                          <p class="text-ivory/80 mt-1">{sub.message}</p>
                        </div>
                      )}
                    </div>

                    <!-- ═══ NEW: No-documents placeholder ═══ -->
                    {hasNoDocuments && sub.status !== "Declined" && (
                      <div class="mt-4 pt-4 border-t border-gold/10">
                        <p class="text-ivory/30 text-sm italic">
                          No documents uploaded yet — contracts and invoices will appear here when ready.
                        </p>
                      </div>
                    )}

                    <!-- Contract -->
                    {contract && (
                      <div class="mt-6 pt-6 border-t border-gold/20">
                        <div class="flex items-start justify-between gap-4">
                          <div>
                            <h4 class="font-display text-lg text-gold mb-2">Contract</h4>
                            <p class="text-ivory/60 text-sm mb-3">
                              Uploaded: {new Date(contract.uploaded_at).toLocaleDateString()}
                            </p>
                            {contract.signed_at ? (
                              <div class="bg-green-500/10 border border-green-500/40 rounded-lg px-4 py-3">
                                <p class="text-green-400 font-semibold mb-1">✓ Signed</p>
                                <p class="text-green-400/80 text-sm">
                                  Signed by {contract.signature_name} on {new Date(contract.signed_at).toLocaleDateString()}
                                </p>
                              </div>
                            ) : (
                              <div class="bg-gold/10 border border-gold/40 rounded-lg px-4 py-3">
                                <p class="text-gold font-semibold mb-1">⚠ Awaiting Signature</p>
                                <p class="text-ivory/70 text-sm">Please review and sign the contract below</p>
                              </div>
                            )}
                          </div>
                          <a
                            href={`/api/contracts/${contract.id}/view`}
                            target="_blank"
                            rel="noopener noreferrer"
                            class="shrink-0 px-4 py-2 rounded-xl bg-gold/20 text-gold hover:bg-gold hover:text-ivory border border-gold/40 font-semibold transition"
                          >
                            View PDF
                          </a>
                        </div>

                        {!contract.signed_at && (
                          <div class="mt-6 bg-charcoal/60 rounded-lg p-4 border border-gold/20">
                            <h5 class="font-display text-gold mb-3">Sign Contract</h5>
                            <form class="sign-contract-form space-y-4" data-contract-id={contract.id}>
                              <div>
                                <label for={`signature-${contract.id}`} class="block text-ivory/80 text-sm mb-2">
                                  Full Name (Signature)
                                </label>
                                <input
                                  type="text"
                                  id={`signature-${contract.id}`}
                                  name="signatureName"
                                  required
                                  class="w-full bg-charcoal/60 frame rounded-xl px-4 py-2 border border-gold/40 focus:border-gold focus:outline-none"
                                  placeholder="Enter your full legal name"
                                />
                              </div>
                              <div class="flex items-start gap-3">
                                <input
                                  type="checkbox"
                                  id={`agree-${contract.id}`}
                                  name="agreed"
                                  required
                                  class="mt-1 w-4 h-4 accent-gold"
                                />
                                <label for={`agree-${contract.id}`} class="text-ivory/80 text-sm">
                                  I have read and agree to the terms and conditions outlined in this contract
                                </label>
                              </div>
                              <button
                                type="submit"
                                class="w-full md:w-auto px-6 py-3 rounded-xl bg-gold text-ivory hover:bg-gold-dark hover:text-rosewood font-semibold frame transition"
                              >
                                Sign Contract
                              </button>
                              <p class="error-message text-rosewood text-sm hidden"></p>
                            </form>
                          </div>
                        )}
                      </div>
                    )}

                    <!-- Invoices -->
                    {subInvoices.length > 0 && (
                      <div class="mt-6 pt-6 border-t border-gold/20">
                        <h4 class="font-display text-lg text-gold mb-3">Invoices & Receipts</h4>
                        <div class="space-y-2">
                          {subInvoices.map((inv) => (
                            <div class="flex items-center justify-between bg-charcoal/60 rounded-lg px-4 py-3 border border-gold/20">
                              <div>
                                <p class="text-ivory/90 font-semibold text-sm">{inv.label}</p>
                                <p class="text-ivory/50 text-xs">
                                  {new Date(inv.uploaded_at).toLocaleDateString()}
                                </p>
                              </div>
                              <a
                                href={`/api/invoices/${inv.id}/view`}
                                class="px-4 py-2 rounded-xl bg-gold text-ivory hover:bg-gold-dark hover:text-rosewood border border-gold/40 text-sm font-semibold frame transition"
                              >
                                Download
                              </a>
                            </div>
                          ))}
                        </div>
                      </div>
                    )}

                    <!-- Review Section — only visible on Complete bookings -->
                    {isComplete && (
                      <div class="mt-6 pt-6 border-t border-gold/20">
                        <h4 class="font-display text-lg text-gold mb-3">Share Your Experience</h4>

                        {existingReview ? (
                          // Already submitted
                          existingReview.approved ? (
                            <div class="bg-emerald-500/10 border border-emerald-500/40 rounded-lg px-4 py-3">
                              <p class="text-emerald-400 font-semibold mb-1">✓ Review Published</p>
                              <p class="text-ivory/70 text-sm italic">"{existingReview.body}"</p>
                            </div>
                          ) : (
                            <div class="bg-gold/10 border border-gold/40 rounded-lg px-4 py-3">
                              <p class="text-gold font-semibold mb-1">⏳ Review Pending Approval</p>
                              <p class="text-ivory/60 text-sm">Thank you — your review will appear on the Memories page once approved.</p>
                            </div>
                          )
                        ) : (
                          // No review yet — show form
                          <form
                            class="review-form space-y-4"
                            data-submission-id={sub.id}
                          >
                            <div>
                              <label
                                for={`review-body-${sub.id}`}
                                class="block text-ivory/80 text-sm mb-2"
                              >
                                How was your experience? <span class="text-ivory/40">(10–1000 characters)</span>
                              </label>
                              <textarea
                                id={`review-body-${sub.id}`}
                                name="reviewBody"
                                rows={4}
                                required
                                maxlength={1000}
                                class="w-full bg-charcoal/60 frame rounded-xl px-4 py-3 border border-gold/40 focus:border-gold focus:outline-none text-ivory placeholder:text-ivory/30 resize-none"
                                placeholder="Share a few words about your experience..."
                              ></textarea>
                              <p class="review-char-count text-ivory/40 text-xs text-right mt-1">0 / 1000</p>
                            </div>
                            <button
                              type="submit"
                              class="px-6 py-2 rounded-xl bg-gold text-ivory hover:bg-gold-dark hover:text-rosewood font-semibold frame transition"
                            >
                              Submit Review
                            </button>
                            <p class="review-error text-rosewood text-sm hidden"></p>
                          </form>
                        )}
                      </div>
                    )}

                    <!-- ═══ NEW: Review availability hint on non-Complete, non-Declined bookings ═══ -->
                    {!isComplete && sub.status !== "Declined" && (
                      <div class="mt-4 pt-4 border-t border-gold/10">
                        <p class="text-ivory/20 text-xs italic">
                          You'll be able to leave a review once your event is complete.
                        </p>
                      </div>
                    )}

                  </article>
                );
              })
            )}
          </section>
        </main>
      </div>
    </div>
  </div>

  <script>
    // ── Logout ────────────────────────────────────────────
    async function handleLogout() {
      try {
        const res = await fetch("/api/auth/logout", { method: "POST" });
        if (res.ok) window.location.href = "/login";
      } catch (err) {
        console.error("Logout failed:", err);
      }
    }
    document.getElementById("logoutBtn")?.addEventListener("click", handleLogout);
    document.getElementById("logoutBtnMobile")?.addEventListener("click", handleLogout);

    // ── Smooth scroll ─────────────────────────────────────
    document.querySelectorAll('a[href^="#"]').forEach(anchor => {
      anchor.addEventListener("click", (e) => {
        e.preventDefault();
        const target = document.querySelector((anchor as HTMLAnchorElement).getAttribute("href")!);
        if (target) target.scrollIntoView({ behavior: "smooth" });
      });
    });

    // ── Profile form ──────────────────────────────────────
    const profileForm = document.getElementById("profileForm") as HTMLFormElement | null;
    profileForm?.addEventListener("submit", async (e) => {
      e.preventDefault();
      const btn = document.getElementById("profileSaveBtn") as HTMLButtonElement;
      const errorEl = document.getElementById("profileError") as HTMLElement;
      const successEl = document.getElementById("profileSuccess") as HTMLElement;
      const formData = new FormData(profileForm);

      const firstName = (formData.get("firstName") as string)?.trim();
      const lastName = (formData.get("lastName") as string)?.trim();
      const prefix = (formData.get("prefix") as string)?.trim();
      const preferredName = (formData.get("preferredName") as string)?.trim() || '';

      if (!firstName || !lastName) {
        errorEl.textContent = "Both first and last name are required.";
        errorEl.classList.remove("hidden");
        successEl.classList.add("hidden");
        return;
      }

      btn.disabled = true;
      btn.textContent = "Saving...";
      errorEl.classList.add("hidden");
      successEl.classList.add("hidden");

      try {
        const res = await fetch("/api/auth/profile", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({ firstName, lastName, prefix, preferredName }),
        });
        const data = await res.json();
        if (!res.ok) throw new Error(data.error || "Failed to save profile");
        window.location.href = '/dashboard';
      } catch (err: any) {
        errorEl.textContent = err.message || "Failed to save profile";
        errorEl.classList.remove("hidden");
        btn.disabled = false;
        btn.textContent = "Save";
      }
    });

    // ── Contract signing ──────────────────────────────────
    document.querySelectorAll(".sign-contract-form").forEach((form) => {
      form.addEventListener("submit", async (e) => {
        e.preventDefault();
        const formEl = e.target as HTMLFormElement;
        const contractId = formEl.dataset.contractId;
        const signatureName = (formEl.querySelector('[name="signatureName"]') as HTMLInputElement).value;
        const agreed = (formEl.querySelector('[name="agreed"]') as HTMLInputElement).checked;
        const errorEl = formEl.querySelector('.error-message') as HTMLElement;
        const submitBtn = formEl.querySelector('button[type="submit"]') as HTMLButtonElement;

        errorEl.classList.add('hidden');
        submitBtn.disabled = true;
        submitBtn.textContent = 'Signing...';

        try {
          const res = await fetch(`/api/contracts/${contractId}/sign`, {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({ signatureName, agreed }),
          });
          const data = await res.json();
          if (!res.ok) throw new Error(data.error || 'Failed to sign contract');
          window.location.reload();
        } catch (err: any) {
          errorEl.textContent = err.message || 'Failed to sign contract';
          errorEl.classList.remove('hidden');
          submitBtn.disabled = false;
          submitBtn.textContent = 'Sign Contract';
        }
      });
    });

    // ── Review char counter ───────────────────────────────
    document.querySelectorAll('.review-form').forEach((form) => {
      const textarea = form.querySelector('textarea') as HTMLTextAreaElement;
      const counter = form.querySelector('.review-char-count') as HTMLElement;
      textarea?.addEventListener('input', () => {
        counter.textContent = `${textarea.value.length} / 1000`;
      });
    });

    // ── Review submission ─────────────────────────────────
    document.querySelectorAll('.review-form').forEach((form) => {
      form.addEventListener('submit', async (e) => {
        e.preventDefault();
        const formEl = e.target as HTMLFormElement;
        const submissionId = Number(formEl.dataset.submissionId);
        const textarea = formEl.querySelector('textarea') as HTMLTextAreaElement;
        const errorEl = formEl.querySelector('.review-error') as HTMLElement;
        const submitBtn = formEl.querySelector('button[type="submit"]') as HTMLButtonElement;
        const reviewBody = textarea.value.trim();

        errorEl.classList.add('hidden');
        submitBtn.disabled = true;
        submitBtn.textContent = 'Submitting...';

        try {
          const res = await fetch('/api/reviews/submit', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ submission_id: submissionId, reviewBody }),
          });
          const data = await res.json();
          if (!res.ok) throw new Error(data.error || 'Failed to submit review');

          formEl.innerHTML = `
            <div class="bg-gold/10 border border-gold/40 rounded-lg px-4 py-3">
              <p class="text-gold font-semibold mb-1">⏳ Review Pending Approval</p>
              <p class="text-ivory/60 text-sm">Thank you — your review will appear on the Memories page once approved.</p>
            </div>
          `;
        } catch (err: any) {
          errorEl.textContent = err.message || 'Failed to submit review';
          errorEl.classList.remove('hidden');
          submitBtn.disabled = false;
          submitBtn.textContent = 'Submit Review';
        }
      });
    });
    // ── Card stagger entrance ─────────────────────────────
    const cards = document.querySelectorAll('.card-enter');
    const cardObserver = new IntersectionObserver(
      (entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            entry.target.classList.add('visible');
            cardObserver.unobserve(entry.target);
          }
        });
      },
      { threshold: 0.05 }
    );
    cards.forEach(el => cardObserver.observe(el));
  </script>
</BaseLayout>