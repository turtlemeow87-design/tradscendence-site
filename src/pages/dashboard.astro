---
import BaseLayout from "../layouts/BaseLayout.astro";
import { neon } from "@neondatabase/serverless";

const user = Astro.locals.user;

if (!user) {
  return Astro.redirect("/login");
}

let submissions: any[] = [];
let contracts: Record<number, any> = {};
let invoices: Record<number, any[]> = {};
let userProfile: { first_name: string | null; last_name: string | null; prefix: string | null } = {
  first_name: null,
  last_name: null,
  prefix: null,
};

if (!import.meta.env.DEV && import.meta.env.DATABASE_URL) {
  const sql = neon(import.meta.env.DATABASE_URL);

  // Fetch user profile + submissions + contracts + invoices in parallel
  const [profileResult, submissionResult] = await Promise.all([
    sql`SELECT first_name, last_name, prefix FROM users WHERE id = ${user.id}`,
    sql`
      SELECT 
        id, first_name, last_name, email, event_date, location, 
        instruments, message, status, created_at
      FROM contact_submissions
      WHERE email = ${user.email}
      ORDER BY created_at DESC
    `,
  ]);

  if (profileResult.length > 0) {
    userProfile = profileResult[0] as typeof userProfile;
  }

  submissions = submissionResult;

  if (submissions.length > 0) {
    const submissionIds = submissions.map(s => s.id);

    const [contractResults, invoiceResults] = await Promise.all([
      sql`
        SELECT submission_id, id, file_url, uploaded_at, signed_at, signature_name
        FROM contracts
        WHERE submission_id = ANY(${submissionIds})
      `,
      sql`
        SELECT id, submission_id, file_url, label, uploaded_at
        FROM invoices
        WHERE submission_id = ANY(${submissionIds})
        ORDER BY submission_id, uploaded_at ASC
      `,
    ]);

    contractResults.forEach(c => {
      contracts[c.submission_id] = c;
    });

    invoiceResults.forEach(inv => {
      if (!invoices[inv.submission_id]) invoices[inv.submission_id] = [];
      invoices[inv.submission_id].push(inv);
    });
  }
}

// ── Greeting logic ──────────────────────────────────────
const needsProfile = !userProfile.last_name || !userProfile.prefix;
let greeting = '';

if (userProfile.prefix && userProfile.last_name) {
  if (userProfile.prefix === 'none') {
    // "Prefer not to disclose" → first initial
    const initial = (userProfile.first_name || user.email)[0].toUpperCase();
    greeting = `Welcome back, ${initial}. ${userProfile.last_name}`;
  } else {
    greeting = `Welcome back, ${userProfile.prefix} ${userProfile.last_name}`;
  }
} else if (userProfile.first_name) {
  greeting = `Welcome back, ${userProfile.first_name}`;
} else {
  greeting = `Welcome back`;
}

const statusColors: Record<string, string> = {
  Pending: "bg-gold/20 text-gold border-gold/40",
  Reviewing: "bg-blue-500/20 text-blue-400 border-blue-500/40",
  "Offer Sent": "bg-purple-500/20 text-purple-400 border-purple-500/40",
  Confirmed: "bg-green-500/20 text-green-400 border-green-500/40",
  Declined: "bg-rosewood/20 text-rosewood border-rosewood/40",
};
---

<BaseLayout
  title="My Account — Tradscendence"
  description="View your booking inquiries and contracts"
  canonical={`${Astro.url.origin}/dashboard`}
>
  <div class="min-h-screen bg-charcoal text-ivory px-4 py-8">
    <div class="max-w-7xl mx-auto">
      <div class="flex flex-col lg:flex-row gap-8">
        
        <!-- Sidebar -->
        <aside class="lg:w-64 shrink-0">
          <div class="bg-charcoal/80 frame rounded-xl p-6 sticky top-20">
            <h2 class="font-display text-xl text-gold mb-4">My Account</h2>
            <nav class="space-y-2">
              <a href="#bookings" class="block px-3 py-2 rounded-lg bg-gold/10 text-gold font-semibold">
                Booking Inquiries
              </a>
            </nav>
            <div class="mt-8 pt-6 border-t border-gold/20">
              <button
                id="logoutBtn"
                class="w-full px-4 py-2 rounded-xl bg-rosewood/20 text-rosewood hover:bg-rosewood hover:text-ivory font-semibold frame transition"
              >
                Sign Out
              </button>
            </div>
          </div>
        </aside>

        <!-- Main Content -->
        <main class="flex-1">
          <div class="mb-8">
            <h1 class="font-display text-3xl md:text-4xl text-gold mb-2">
              {greeting}
            </h1>
            <p class="text-ivory/70">Manage your booking inquiries and documents</p>
          </div>

          <!-- Profile Completion Card (shown only if name/prefix missing) -->
          {needsProfile && (
            <section id="profileCard" class="mb-8 bg-gold/5 border border-gold/40 rounded-xl p-6 frame">
              <h2 class="font-display text-xl text-gold mb-2">Complete Your Profile</h2>
              <p class="text-ivory/70 text-sm mb-5">
                Help us greet you properly — choose how you'd like to be addressed.
              </p>
              <form id="profileForm" class="space-y-4">
                <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                  <label class="flex flex-col gap-1">
                    <span class="text-ivory/80 text-sm font-display">First Name *</span>
                    <input
                      type="text"
                      name="firstName"
                      required
                      value={userProfile.first_name || ''}
                      class="bg-ebony/60 frame rounded-xl px-3 py-2 border border-[var(--accent-bronze)] text-ivory placeholder:text-ivory/30 focus:outline-none focus:border-gold"
                    />
                  </label>
                  <label class="flex flex-col gap-1">
                    <span class="text-ivory/80 text-sm font-display">Last Name *</span>
                    <input
                      type="text"
                      name="lastName"
                      required
                      value={userProfile.last_name || ''}
                      class="bg-ebony/60 frame rounded-xl px-3 py-2 border border-[var(--accent-bronze)] text-ivory placeholder:text-ivory/30 focus:outline-none focus:border-gold"
                    />
                  </label>
                </div>

                {!userProfile.prefix && (
                  <label class="flex flex-col gap-1">
  <span class="text-ivory/80 text-sm font-display">How would you like to be addressed?</span>
  <select
    name="prefix"
    required
    class="bg-ebony/60 frame rounded-xl px-3 py-2 border border-[var(--accent-bronze)] text-ivory focus:outline-none focus:border-gold"
  >
    <option value="" disabled selected>Select a prefix</option>
    <option value="Mr.">Mr.</option>
    <option value="Mrs.">Mrs.</option>
    <option value="Ms.">Ms.</option>
    <option value="none">Prefer not to disclose</option>
  </select>
</label>
                )}

                <div class="flex items-center gap-4">
                  <button
                    type="submit"
                    id="profileSaveBtn"
                    class="rounded-xl px-6 py-2 bg-gold text-ivory hover:bg-gold-dark hover:text-rosewood font-semibold frame transition"
                  >
                    Save
                  </button>
                  <p id="profileError" class="text-rosewood text-sm hidden"></p>
                  <p id="profileSuccess" class="text-green-400 text-sm hidden"></p>
                </div>
              </form>
            </section>
          )}

          <!-- Bookings Section -->
          <section id="bookings" class="scroll-mt-20 space-y-6">
            {submissions.length === 0 ? (
              <div class="bg-charcoal/80 frame rounded-xl p-8 text-center">
                <p class="text-ivory/70 mb-4">No booking inquiries yet</p>
                <a
                  href="/contact"
                  class="inline-block rounded-xl px-6 py-3 bg-gold text-ivory hover:bg-gold-dark hover:text-rosewood font-semibold frame transition"
                >
                  Submit Inquiry
                </a>
              </div>
            ) : (
              submissions.map((sub) => {
                const contract = contracts[sub.id];
                const subInvoices = invoices[sub.id] || [];
                const displayName = [sub.first_name, sub.last_name].filter(Boolean).join(' ') || sub.email;
                return (
                  <article class="bg-charcoal/80 frame rounded-xl p-6" data-submission-id={sub.id}>
                    <!-- Submission Header -->
                    <div class="flex flex-wrap items-start justify-between gap-4 mb-4">
                      <div>
                        <h3 class="font-display text-xl text-gold mb-1">
                          {sub.location || "Booking Inquiry"}
                        </h3>
                        {sub.event_date && (
                          <p class="text-ivory/60 text-sm">
                            Event Date: {new Date(sub.event_date).toLocaleDateString()}
                          </p>
                        )}
                        <p class="text-ivory/60 text-sm">
                          Submitted: {new Date(sub.created_at).toLocaleDateString()}
                        </p>
                      </div>
                      <span class={`px-3 py-1 rounded-lg border text-sm font-semibold ${statusColors[sub.status] || statusColors.Pending}`}>
                        {sub.status}
                      </span>
                    </div>

                    <!-- Submission Details -->
                    <div class="grid md:grid-cols-2 gap-4 mb-4 text-sm">
                      {sub.instruments && sub.instruments.length > 0 && (
                        <div>
                          <span class="text-gold font-semibold">Instruments:</span>
                          <span class="text-ivory/80 ml-2">{sub.instruments.join(", ")}</span>
                        </div>
                      )}
                      {sub.message && (
                        <div class="md:col-span-2">
                          <span class="text-gold font-semibold">Message:</span>
                          <p class="text-ivory/80 mt-1">{sub.message}</p>
                        </div>
                      )}
                    </div>

                    <!-- Contract Section -->
                    {contract && (
                      <div class="mt-6 pt-6 border-t border-gold/20">
                        <div class="flex items-start justify-between gap-4">
                          <div>
                            <h4 class="font-display text-lg text-gold mb-2">Contract</h4>
                            <p class="text-ivory/60 text-sm mb-3">
                              Uploaded: {new Date(contract.uploaded_at).toLocaleDateString()}
                            </p>
                            
                            {contract.signed_at ? (
                              <div class="bg-green-500/10 border border-green-500/40 rounded-lg px-4 py-3">
                                <p class="text-green-400 font-semibold mb-1">✓ Signed</p>
                                <p class="text-green-400/80 text-sm">
                                  Signed by {contract.signature_name} on {new Date(contract.signed_at).toLocaleDateString()}
                                </p>
                              </div>
                            ) : (
                              <div class="bg-gold/10 border border-gold/40 rounded-lg px-4 py-3">
                                <p class="text-gold font-semibold mb-1">⚠ Awaiting Signature</p>
                                <p class="text-ivory/70 text-sm">Please review and sign the contract below</p>
                              </div>
                            )}
                          </div>
                          
                          <a
                            href={contract.file_url}
                            target="_blank"
                            rel="noopener noreferrer"
                            class="shrink-0 px-4 py-2 rounded-xl bg-gold/20 text-gold hover:bg-gold hover:text-ivory border border-gold/40 font-semibold transition"
                          >
                            View PDF
                          </a>
                        </div>

                        {!contract.signed_at && (
                          <div class="mt-6 bg-charcoal/60 rounded-lg p-4 border border-gold/20">
                            <h5 class="font-display text-gold mb-3">Sign Contract</h5>
                            <form class="sign-contract-form space-y-4" data-contract-id={contract.id}>
                              <div>
                                <label for={`signature-${contract.id}`} class="block text-ivory/80 text-sm mb-2">
                                  Full Name (Signature)
                                </label>
                                <input
                                  type="text"
                                  id={`signature-${contract.id}`}
                                  name="signatureName"
                                  required
                                  class="w-full bg-charcoal/60 frame rounded-xl px-4 py-2 border border-gold/40 focus:border-gold focus:outline-none"
                                  placeholder="Enter your full legal name"
                                />
                              </div>
                              
                              <div class="flex items-start gap-3">
                                <input
                                  type="checkbox"
                                  id={`agree-${contract.id}`}
                                  name="agreed"
                                  required
                                  class="mt-1 w-4 h-4 accent-gold"
                                />
                                <label for={`agree-${contract.id}`} class="text-ivory/80 text-sm">
                                  I have read and agree to the terms and conditions outlined in this contract
                                </label>
                              </div>

                              <button
                                type="submit"
                                class="w-full md:w-auto px-6 py-3 rounded-xl bg-gold text-ivory hover:bg-gold-dark hover:text-rosewood font-semibold frame transition"
                              >
                                Sign Contract
                              </button>
                              
                              <p class="error-message text-rosewood text-sm hidden"></p>
                            </form>
                          </div>
                        )}
                      </div>
                    )}

                    <!-- Invoices Section -->
                    {subInvoices.length > 0 && (
                      <div class="mt-6 pt-6 border-t border-gold/20">
                        <h4 class="font-display text-lg text-gold mb-3">Invoices & Receipts</h4>
                        <div class="space-y-2">
                          {subInvoices.map((inv) => (
                            <div class="flex items-center justify-between bg-charcoal/60 rounded-lg px-4 py-3 border border-gold/20">
                              <div>
                                <p class="text-ivory/90 font-semibold text-sm">{inv.label}</p>
                                <p class="text-ivory/50 text-xs">
                                  {new Date(inv.uploaded_at).toLocaleDateString()}
                                </p>
                              </div>
                              <a
                                href={inv.file_url}
                                target="_blank"
                                rel="noopener noreferrer"
                                download
                                class="px-4 py-2 rounded-xl bg-gold text-ivory hover:bg-gold-dark hover:text-rosewood border border-gold/40 text-sm font-semibold frame transition"
                              >
                                Download
                              </a>
                            </div>
                          ))}
                        </div>
                      </div>
                    )}
                  </article>
                );
              })
            )}
          </section>
        </main>
      </div>
    </div>
  </div>

  <script>
    // ── Logout ────────────────────────────────────────────
    document.getElementById("logoutBtn")?.addEventListener("click", async () => {
      try {
        const res = await fetch("/api/auth/logout", { method: "POST" });
        if (res.ok) window.location.href = "/login";
      } catch (err) {
        console.error("Logout failed:", err);
      }
    });

    // ── Profile completion form ───────────────────────────
    const profileForm = document.getElementById("profileForm") as HTMLFormElement | null;
    profileForm?.addEventListener("submit", async (e) => {
      e.preventDefault();

      const btn = document.getElementById("profileSaveBtn") as HTMLButtonElement;
      const errorEl = document.getElementById("profileError") as HTMLElement;
      const successEl = document.getElementById("profileSuccess") as HTMLElement;
      const formData = new FormData(profileForm);

      const firstName = (formData.get("firstName") as string)?.trim();
      const lastName = (formData.get("lastName") as string)?.trim();
      const prefix = (formData.get("prefix") as string)?.trim();

      if (!firstName || !lastName) {
        errorEl.textContent = "Both first and last name are required.";
        errorEl.classList.remove("hidden");
        successEl.classList.add("hidden");
        return;
      }

      btn.disabled = true;
      btn.textContent = "Saving...";
      errorEl.classList.add("hidden");
      successEl.classList.add("hidden");

      try {
        const res = await fetch("/api/auth/profile", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({ firstName, lastName, prefix }),
        });

        const data = await res.json();
        if (!res.ok) throw new Error(data.error || "Failed to save profile");

        // Reload to show updated greeting
        window.location.reload();
      } catch (err: any) {
        errorEl.textContent = err.message || "Failed to save profile";
        errorEl.classList.remove("hidden");
        btn.disabled = false;
        btn.textContent = "Save";
      }
    });

    // ── Contract signing ──────────────────────────────────
    document.querySelectorAll(".sign-contract-form").forEach((form) => {
      form.addEventListener("submit", async (e) => {
        e.preventDefault();
        
        const formEl = e.target as HTMLFormElement;
        const contractId = formEl.dataset.contractId;
        const signatureName = (formEl.querySelector('[name="signatureName"]') as HTMLInputElement).value;
        const agreed = (formEl.querySelector('[name="agreed"]') as HTMLInputElement).checked;
        const errorEl = formEl.querySelector('.error-message') as HTMLElement;
        const submitBtn = formEl.querySelector('button[type="submit"]') as HTMLButtonElement;

        errorEl.classList.add('hidden');
        submitBtn.disabled = true;
        submitBtn.textContent = 'Signing...';

        try {
          const res = await fetch(`/api/contracts/${contractId}/sign`, {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({ signatureName, agreed }),
          });

          const data = await res.json();
          if (!res.ok) throw new Error(data.error || 'Failed to sign contract');

          window.location.reload();
        } catch (err: any) {
          errorEl.textContent = err.message || 'Failed to sign contract';
          errorEl.classList.remove('hidden');
          submitBtn.disabled = false;
          submitBtn.textContent = 'Sign Contract';
        }
      });
    });
  </script>
</BaseLayout>